package windows_polyfill

// Union polyfill: byte-offset read/write helpers for @C struct union fields.
// The @C struct itself (with VArray<UInt8, $N> _raw) is generated by bindgen
// at the actual size required. Caller ensures byteOffset + sizeof(T) <= capacity.

// ---------------------------------------------------------------------------
// Byte-offset read helpers
// ---------------------------------------------------------------------------

public unsafe func unionReadUInt8(base: CPointer<UInt8>, byteOffset: Int64): UInt8 {
    return (base + byteOffset).read()
}
public unsafe func unionReadInt8(base: CPointer<UInt8>, byteOffset: Int64): Int8 {
    return CPointer<Int8>(base + byteOffset).read()
}
public unsafe func unionReadUInt16(base: CPointer<UInt8>, byteOffset: Int64): UInt16 {
    return CPointer<UInt16>(base + byteOffset).read()
}
public unsafe func unionReadInt16(base: CPointer<UInt8>, byteOffset: Int64): Int16 {
    return CPointer<Int16>(base + byteOffset).read()
}
public unsafe func unionReadUInt32(base: CPointer<UInt8>, byteOffset: Int64): UInt32 {
    return CPointer<UInt32>(base + byteOffset).read()
}
public unsafe func unionReadInt32(base: CPointer<UInt8>, byteOffset: Int64): Int32 {
    return CPointer<Int32>(base + byteOffset).read()
}
public unsafe func unionReadUInt64(base: CPointer<UInt8>, byteOffset: Int64): UInt64 {
    return CPointer<UInt64>(base + byteOffset).read()
}
public unsafe func unionReadInt64(base: CPointer<UInt8>, byteOffset: Int64): Int64 {
    return CPointer<Int64>(base + byteOffset).read()
}
public unsafe func unionReadFloat32(base: CPointer<UInt8>, byteOffset: Int64): Float32 {
    return CPointer<Float32>(base + byteOffset).read()
}
public unsafe func unionReadFloat64(base: CPointer<UInt8>, byteOffset: Int64): Float64 {
    return CPointer<Float64>(base + byteOffset).read()
}

// ---------------------------------------------------------------------------
// Byte-offset write helpers
// ---------------------------------------------------------------------------

public unsafe func unionWriteUInt8(base: CPointer<UInt8>, byteOffset: Int64, v: UInt8): Unit {
    (base + byteOffset).write(v)
}
public unsafe func unionWriteInt8(base: CPointer<UInt8>, byteOffset: Int64, v: Int8): Unit {
    CPointer<Int8>(base + byteOffset).write(v)
}
public unsafe func unionWriteUInt16(base: CPointer<UInt8>, byteOffset: Int64, v: UInt16): Unit {
    CPointer<UInt16>(base + byteOffset).write(v)
}
public unsafe func unionWriteInt16(base: CPointer<UInt8>, byteOffset: Int64, v: Int16): Unit {
    CPointer<Int16>(base + byteOffset).write(v)
}
public unsafe func unionWriteUInt32(base: CPointer<UInt8>, byteOffset: Int64, v: UInt32): Unit {
    CPointer<UInt32>(base + byteOffset).write(v)
}
public unsafe func unionWriteInt32(base: CPointer<UInt8>, byteOffset: Int64, v: Int32): Unit {
    CPointer<Int32>(base + byteOffset).write(v)
}
public unsafe func unionWriteUInt64(base: CPointer<UInt8>, byteOffset: Int64, v: UInt64): Unit {
    CPointer<UInt64>(base + byteOffset).write(v)
}
public unsafe func unionWriteInt64(base: CPointer<UInt8>, byteOffset: Int64, v: Int64): Unit {
    CPointer<Int64>(base + byteOffset).write(v)
}
public unsafe func unionWriteFloat32(base: CPointer<UInt8>, byteOffset: Int64, v: Float32): Unit {
    CPointer<Float32>(base + byteOffset).write(v)
}
public unsafe func unionWriteFloat64(base: CPointer<UInt8>, byteOffset: Int64, v: Float64): Unit {
    CPointer<Float64>(base + byteOffset).write(v)
}
