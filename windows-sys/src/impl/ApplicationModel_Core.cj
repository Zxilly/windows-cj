        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IUnhandledErrorDetectedEventArgs {
        IUnhandledErrorDetectedEventArgs(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IUnhandledErrorDetectedEventArgs {
        IUnhandledErrorDetectedEventArgs(raw)
    }

    public static func iid(): GUID {
        return GUID(0x679AB78B, 0xB336, 0x4822, 0xAC, 0x40, 0x0D, 0x75, 0x0F, 0x0B, 0x7A, 0x2B)
    }

    public static func descriptor(): InterfaceDescriptor<IUnhandledErrorDetectedEventArgs> {
        return InterfaceDescriptor<IUnhandledErrorDetectedEventArgs>("IUnhandledErrorDetectedEventArgs", IUnhandledErrorDetectedEventArgs.iid(), takeIUnhandledErrorDetectedEventArgsFromAbi, viewIUnhandledErrorDetectedEventArgs)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IUnhandledErrorDetectedEventArgsVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IUnhandledErrorDetectedEventArgsVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IUnhandledErrorDetectedEventArgsVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func UnhandledError(): CPointer<Unit> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.UnhandledError(__liveRaw)
    }
}
