            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }
}

@When[Windows_Storage_Streams == "on"]
@C
public struct InputStreamOptions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: InputStreamOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: InputStreamOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: InputStreamOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: InputStreamOptions): InputStreamOptions {
        return InputStreamOptions(this.value | other.value)
    }
    public operator func &(other: InputStreamOptions): InputStreamOptions {
        return InputStreamOptions(this.value & other.value)
    }
    public operator func !(): InputStreamOptions {
        return InputStreamOptions(!this.value)
    }
}

@When[Windows_Storage_Streams == "on"]
public let None: InputStreamOptions = InputStreamOptions(0)

@When[Windows_Storage_Streams == "on"]
public let Partial: InputStreamOptions = InputStreamOptions(1)

@When[Windows_Storage_Streams == "on"]
public let ReadAhead: InputStreamOptions = InputStreamOptions(2)

