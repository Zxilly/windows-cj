@C
public struct TextPredictionOptions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: TextPredictionOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TextPredictionOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: TextPredictionOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: TextPredictionOptions): TextPredictionOptions {
        return TextPredictionOptions(this.value | other.value)
    }
    public operator func &(other: TextPredictionOptions): TextPredictionOptions {
        return TextPredictionOptions(this.value & other.value)
    }
    public operator func !(): TextPredictionOptions {
        return TextPredictionOptions(!this.value)
    }
}

