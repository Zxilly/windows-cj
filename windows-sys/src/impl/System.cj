@When[Windows_System == "on"]
@C
public struct VirtualKeyModifiers {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: VirtualKeyModifiers): Bool {
        return this.value == other.value
    }
    public operator func !=(other: VirtualKeyModifiers): Bool {
        return this.value != other.value
    }

    public func contains(other: VirtualKeyModifiers): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: VirtualKeyModifiers): VirtualKeyModifiers {
        return VirtualKeyModifiers(this.value | other.value)
    }
    public operator func &(other: VirtualKeyModifiers): VirtualKeyModifiers {
        return VirtualKeyModifiers(this.value & other.value)
    }
    public operator func !(): VirtualKeyModifiers {
        return VirtualKeyModifiers(!this.value)
    }
}

@When[Windows_System == "on"]
public let None: VirtualKeyModifiers = VirtualKeyModifiers(0)

@When[Windows_System == "on"]
public let Control: VirtualKeyModifiers = VirtualKeyModifiers(1)

@When[Windows_System == "on"]
public let Menu: VirtualKeyModifiers = VirtualKeyModifiers(2)

@When[Windows_System == "on"]
public let Shift: VirtualKeyModifiers = VirtualKeyModifiers(4)

@When[Windows_System == "on"]
public let Windows: VirtualKeyModifiers = VirtualKeyModifiers(8)
