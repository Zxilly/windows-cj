    }

    public operator func |(other: WebAccountSelectionOptions): WebAccountSelectionOptions {
        return WebAccountSelectionOptions(this.value | other.value)
    }
    public operator func &(other: WebAccountSelectionOptions): WebAccountSelectionOptions {
        return WebAccountSelectionOptions(this.value & other.value)
    }
    public operator func !(): WebAccountSelectionOptions {
        return WebAccountSelectionOptions(!this.value)
    }
}

@When[Windows_Security_Authentication_Web_Provider == "on"]
public let Default: WebAccountSelectionOptions = WebAccountSelectionOptions(0)

@When[Windows_Security_Authentication_Web_Provider == "on"]
public let New: WebAccountSelectionOptions = WebAccountSelectionOptions(1)
