    public operator func ==(other: PointOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PointOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: PointOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: PointOptions): PointOptions {
        return PointOptions(this.value | other.value)
    }
    public operator func &(other: PointOptions): PointOptions {
        return PointOptions(this.value & other.value)
    }
    public operator func !(): PointOptions {
        return PointOptions(!this.value)
    }
}

