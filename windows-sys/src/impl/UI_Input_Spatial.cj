public struct SpatialGestureSettings {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: SpatialGestureSettings): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SpatialGestureSettings): Bool {
        return this.value != other.value
    }

    public func contains(other: SpatialGestureSettings): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: SpatialGestureSettings): SpatialGestureSettings {
        return SpatialGestureSettings(this.value | other.value)
    }
    public operator func &(other: SpatialGestureSettings): SpatialGestureSettings {
        return SpatialGestureSettings(this.value & other.value)
    }
    public operator func !(): SpatialGestureSettings {
        return SpatialGestureSettings(!this.value)
    }
}

