@When[Windows_Security_Credentials == "on"]
@C
public struct WebAccountState {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: WebAccountState): Bool {
        return this.value == other.value
    }
    public operator func !=(other: WebAccountState): Bool {
        return this.value != other.value
    }
}

@When[Windows_Security_Credentials == "on"]
public let WebAccountState_None: WebAccountState = WebAccountState(0)

@When[Windows_Security_Credentials == "on"]
