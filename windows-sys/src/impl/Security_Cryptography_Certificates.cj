@When[Windows_Security_Cryptography_Certificates == "on"]
@C
public struct InstallOptions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: InstallOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: InstallOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: InstallOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: InstallOptions): InstallOptions {
        return InstallOptions(this.value | other.value)
    }
    public operator func &(other: InstallOptions): InstallOptions {
        return InstallOptions(this.value & other.value)
    }
    public operator func !(): InstallOptions {
        return InstallOptions(!this.value)
    }
}

