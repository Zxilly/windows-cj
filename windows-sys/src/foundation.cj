// --- POINT struct ---
@C
public struct POINT {
    public var x: Int32 = 0
    public var y: Int32 = 0

    public init() {}

    public init(x: Int32, y: Int32) {
        this.x = x
        this.y = y
    }
}

// --- RECT struct ---
@C
public struct RECT {
    public var left: Int32 = 0
    public var top: Int32 = 0
    public var right: Int32 = 0
    public var bottom: Int32 = 0

    public init() {}

    public init(left: Int32, top: Int32, right: Int32, bottom: Int32) {
        this.left = left
        this.top = top
        this.right = right
        this.bottom = bottom
    }
}

// --- SIZE struct ---
@C
public struct SIZE {
    public var cx: Int32 = 0
    public var cy: Int32 = 0

    public init() {}

    public init(cx: Int32, cy: Int32) {
        this.cx = cx
        this.cy = cy
    }
}

// --- FILETIME struct ---
@C
public struct FILETIME {
    public var dwLowDateTime: UInt32 = 0
    public var dwHighDateTime: UInt32 = 0

    public init() {}

    public init(dwLowDateTime: UInt32, dwHighDateTime: UInt32) {
        this.dwLowDateTime = dwLowDateTime
        this.dwHighDateTime = dwHighDateTime
    }
}

// --- SECURITY_ATTRIBUTES struct ---
@C
public struct SECURITY_ATTRIBUTES {
    public var nLength: UInt32 = 0
    public var lpSecurityDescriptor: CPointer<Unit> = CPointer<Unit>()
    public var bInheritHandle: Int32 = 0

    public init() {}
}
