        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func Create(label: CPointer<UInt16>): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.Create(liveRaw, label)
    }

    public unsafe func CreateWithHandler(label: CPointer<UInt16>, action: UICommandInvokedHandler): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.CreateWithHandler(liveRaw, label, action)
    }

    public unsafe func CreateWithHandlerAndId(label: CPointer<UInt16>, action: UICommandInvokedHandler, commandId: CPointer<Unit>): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.CreateWithHandlerAndId(liveRaw, label, action, commandId)
    }
}

@When[Windows_UI_Popups == "on"]
@C
public struct MessageDialogOptions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: MessageDialogOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: MessageDialogOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: MessageDialogOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: MessageDialogOptions): MessageDialogOptions {
        return MessageDialogOptions(this.value | other.value)
    }
    public operator func &(other: MessageDialogOptions): MessageDialogOptions {
        return MessageDialogOptions(this.value & other.value)
    }
    public operator func !(): MessageDialogOptions {
        return MessageDialogOptions(!this.value)
    }
}

@When[Windows_UI_Popups == "on"]
public let None: MessageDialogOptions = MessageDialogOptions(0)

@When[Windows_UI_Popups == "on"]
public let AcceptUserInputAfterDelay: MessageDialogOptions = MessageDialogOptions(1)

@When[Windows_UI_Popups == "on"]
@C
public struct Placement {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: Placement): Bool {
        return this.value == other.value
    }
    public operator func !=(other: Placement): Bool {
        return this.value != other.value
    }
}

@When[Windows_UI_Popups == "on"]
public let Default: Placement = Placement(0)

@When[Windows_UI_Popups == "on"]
public let Above: Placement = Placement(1)

@When[Windows_UI_Popups == "on"]
public let Below: Placement = Placement(2)

@When[Windows_UI_Popups == "on"]
public let Left: Placement = Placement(3)

@When[Windows_UI_Popups == "on"]
public let Right: Placement = Placement(4)

@When[Windows_UI_Popups == "on"]
public type UICommandInvokedHandler = CFunc<(CPointer<Unit>) -> Unit>
