@When[Windows_UI_Input_Preview_Text == "on"]
public let NativeEudc: TextConversionMode = TextConversionMode(11)

@When[Windows_UI_Input_Preview_Text == "on"]
@C
public struct TextInputServiceSubscription {
    public var requiredEnabledFeatures: TextBoxFeatures = TextBoxFeatures()
    public var requiredDisabledFeatures: TextBoxFeatures = TextBoxFeatures()
    public init() {}
}

@When[Windows_UI_Input_Preview_Text == "on"]
@C
public struct TextStyle {
    public var mask: TextStyleAttributes = TextStyleAttributes()
    public var textColor: UI.Color = UI.Color()
    public var backgroundColor: UI.Color = UI.Color()
    public var underlineColor: UI.Color = UI.Color()
    public var underlineType: impl.UnderlineType = impl.UnderlineType()
    public init() {}
}

@When[Windows_UI_Input_Preview_Text == "on"]
@C
public struct TextStyleAttributes {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: TextStyleAttributes): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TextStyleAttributes): Bool {
        return this.value != other.value
    }

    public func contains(other: TextStyleAttributes): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: TextStyleAttributes): TextStyleAttributes {
        return TextStyleAttributes(this.value | other.value)
    }
    public operator func &(other: TextStyleAttributes): TextStyleAttributes {
        return TextStyleAttributes(this.value & other.value)
    }
    public operator func !(): TextStyleAttributes {
        return TextStyleAttributes(!this.value)
    }
}

@When[Windows_UI_Input_Preview_Text == "on"]
public let None: TextStyleAttributes = TextStyleAttributes(0)

@When[Windows_UI_Input_Preview_Text == "on"]
public let TextColor: TextStyleAttributes = TextStyleAttributes(1)

@When[Windows_UI_Input_Preview_Text == "on"]
public let BackgroundColor: TextStyleAttributes = TextStyleAttributes(2)

@When[Windows_UI_Input_Preview_Text == "on"]
public let UnderlineColor: TextStyleAttributes = TextStyleAttributes(4)

@When[Windows_UI_Input_Preview_Text == "on"]
public let UnderlineType: TextStyleAttributes = TextStyleAttributes(8)
