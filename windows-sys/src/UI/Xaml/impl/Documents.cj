@When[Windows_UI_Xaml_Documents == "on"]
@C
public struct IUnderlineVtbl {
    public var base_: IInspectableVtbl = IInspectableVtbl()
    public init() {}
}

@When[Windows_UI_Xaml_Documents == "on"]
func takeIUnderlineFromAbi(raw: CPointer<Unit>): IUnderline {
    IUnderline.fromAbiTake(raw)
}

@When[Windows_UI_Xaml_Documents == "on"]
func viewIUnderline(raw: CPointer<Unit>): IUnderline {
    IUnderline(raw)
}

@When[Windows_UI_Xaml_Documents == "on"]
public class IUnderline <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IUnderline {
        IUnderline(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IUnderline {
        IUnderline(raw)
    }

    public static func iid(): GUID {
        return GUID(0xA5FA8202, 0x61C0, 0x47D7, 0x93, 0xEF, 0xBC, 0x0B, 0x57, 0x7C, 0x5F, 0x26)
    }

    public static func descriptor(): InterfaceDescriptor<IUnderline> {
        return InterfaceDescriptor<IUnderline>("IUnderline", IUnderline.iid(), takeIUnderlineFromAbi, viewIUnderline)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IUnderlineVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IUnderlineVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IUnderlineVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }
}

