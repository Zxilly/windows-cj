@When[Windows_UI_Xaml == "on"]
public struct Vector3TransitionComponents {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: Vector3TransitionComponents): Bool {
        return this.value == other.value
    }
    public operator func !=(other: Vector3TransitionComponents): Bool {
        return this.value != other.value
    }

    public func contains(other: Vector3TransitionComponents): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: Vector3TransitionComponents): Vector3TransitionComponents {
        return Vector3TransitionComponents(this.value | other.value)
    }
    public operator func &(other: Vector3TransitionComponents): Vector3TransitionComponents {
        return Vector3TransitionComponents(this.value & other.value)
    }
    public operator func !(): Vector3TransitionComponents {
        return Vector3TransitionComponents(!this.value)
    }
}

@When[Windows_UI_Xaml == "on"]
public let Vector3TransitionComponents_X: Vector3TransitionComponents = Vector3TransitionComponents(1)

