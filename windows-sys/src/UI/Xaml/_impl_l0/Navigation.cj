@When[Windows_UI_Xaml_Navigation == "on"]
public struct NavigationMode {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: NavigationMode): Bool {
        return this.value == other.value
    }
    public operator func !=(other: NavigationMode): Bool {
        return this.value != other.value
    }
}

@When[Windows_UI_Xaml_Navigation == "on"]
public let NavigationMode_New: NavigationMode = NavigationMode(0)

@When[Windows_UI_Xaml_Navigation == "on"]
public let NavigationMode_Back: NavigationMode = NavigationMode(1)

@When[Windows_UI_Xaml_Navigation == "on"]
public let NavigationMode_Forward: NavigationMode = NavigationMode(2)

@When[Windows_UI_Xaml_Navigation == "on"]
public let NavigationMode_Refresh: NavigationMode = NavigationMode(3)
