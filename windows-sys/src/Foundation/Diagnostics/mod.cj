@When[Windows_Foundation_Diagnostics == "on"]
@C
public struct ILoggingOptionsVtbl {
    public var base_: IInspectableVtbl = IInspectableVtbl()
    public var Keywords: CFunc<(CPointer<Unit>) -> Int64> = { _ => 0 }
    public var SetKeywords: CFunc<(CPointer<Unit>, Int64) -> Unit> = { _, _ => () }
    public var Tags: CFunc<(CPointer<Unit>) -> Int32> = { _ => 0 }
    public var SetTags: CFunc<(CPointer<Unit>, Int32) -> Unit> = { _, _ => () }
    public var Task: CFunc<(CPointer<Unit>) -> Int16> = { _ => 0 }
