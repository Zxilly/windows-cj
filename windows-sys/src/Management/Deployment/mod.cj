    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: PackageStatus): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PackageStatus): Bool {
        return this.value != other.value
    }

    public func contains(other: PackageStatus): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: PackageStatus): PackageStatus {
        return PackageStatus(this.value | other.value)
    }
    public operator func &(other: PackageStatus): PackageStatus {
        return PackageStatus(this.value & other.value)
    }
    public operator func !(): PackageStatus {
        return PackageStatus(!this.value)
    }
}

@When[Windows_Management_Deployment == "on"]
public let PackageStatus_OK: PackageStatus = PackageStatus(0)

