            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func SourceRect(): Foundation_impl.Rect {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.SourceRect(liveRaw)
    }

    public unsafe func SetSourceRect(value: Foundation_impl.Rect): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.SetSourceRect(liveRaw, value)
    }

    public unsafe func DestinationWidth(): UInt32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.DestinationWidth(liveRaw)
    }

    public unsafe func SetDestinationWidth(value: UInt32): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.SetDestinationWidth(liveRaw, value)
    }

    public unsafe func DestinationHeight(): UInt32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.DestinationHeight(liveRaw)
    }

    public unsafe func SetDestinationHeight(value: UInt32): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.SetDestinationHeight(liveRaw, value)
    }

    public unsafe func BackgroundColor(): UI.Color {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.BackgroundColor(liveRaw)
    }

    public unsafe func SetBackgroundColor(value: UI.Color): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.SetBackgroundColor(liveRaw, value)
    }

    public unsafe func IsIgnoringHighContrast(): Bool {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.IsIgnoringHighContrast(liveRaw)
    }

    public unsafe func SetIsIgnoringHighContrast(value: Bool): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.SetIsIgnoringHighContrast(liveRaw, value)
    }

    public unsafe func BitmapEncoderId(): GUID {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.BitmapEncoderId(liveRaw)
    }

    public unsafe func SetBitmapEncoderId(value: GUID): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.SetBitmapEncoderId(liveRaw, value)
    }
