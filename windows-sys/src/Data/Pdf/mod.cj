@When[Windows_Data_Pdf == "on"]
@C
public struct PdfPageRotation {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: PdfPageRotation): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PdfPageRotation): Bool {
        return this.value != other.value
    }
}

@When[Windows_Data_Pdf == "on"]
public let Normal: PdfPageRotation = PdfPageRotation(0)

@When[Windows_Data_Pdf == "on"]
public let Rotate90: PdfPageRotation = PdfPageRotation(1)

@When[Windows_Data_Pdf == "on"]
public let Rotate180: PdfPageRotation = PdfPageRotation(2)

@When[Windows_Data_Pdf == "on"]
public let Rotate270: PdfPageRotation = PdfPageRotation(3)
