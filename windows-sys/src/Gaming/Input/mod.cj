@When[Windows_Gaming_Input == "on"]
@C
public struct OptionalUINavigationButtons {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: OptionalUINavigationButtons): Bool {
        return this.value == other.value
    }
    public operator func !=(other: OptionalUINavigationButtons): Bool {
        return this.value != other.value
    }

    public func contains(other: OptionalUINavigationButtons): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: OptionalUINavigationButtons): OptionalUINavigationButtons {
        return OptionalUINavigationButtons(this.value | other.value)
    }
    public operator func &(other: OptionalUINavigationButtons): OptionalUINavigationButtons {
        return OptionalUINavigationButtons(this.value & other.value)
    }
    public operator func !(): OptionalUINavigationButtons {
        return OptionalUINavigationButtons(!this.value)
    }
}

