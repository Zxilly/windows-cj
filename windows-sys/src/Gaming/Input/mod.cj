@When[Windows_Gaming_Input == "on"]
@C
public struct RacingWheelButtons {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: RacingWheelButtons): Bool {
        return this.value == other.value
    }
    public operator func !=(other: RacingWheelButtons): Bool {
        return this.value != other.value
    }

    public func contains(other: RacingWheelButtons): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: RacingWheelButtons): RacingWheelButtons {
        return RacingWheelButtons(this.value | other.value)
    }
    public operator func &(other: RacingWheelButtons): RacingWheelButtons {
        return RacingWheelButtons(this.value & other.value)
    }
    public operator func !(): RacingWheelButtons {
        return RacingWheelButtons(!this.value)
    }
}

