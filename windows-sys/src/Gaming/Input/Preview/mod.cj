            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func FromGameController(controller: CPointer<Unit>): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.FromGameController(liveRaw, controller)
    }

    public unsafe func FromGameControllerProvider(provider: CPointer<Unit>): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.FromGameControllerProvider(liveRaw, provider)
    }

    public unsafe func PairPilotToCopilot(user: CPointer<Unit>, pilotControllerProviderId: CPointer<UInt16>, copilotControllerProviderId: CPointer<UInt16>): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.PairPilotToCopilot(liveRaw, user, pilotControllerProviderId, copilotControllerProviderId)
    }

    public unsafe func ClearPairing(user: CPointer<Unit>, controllerProviderId: CPointer<UInt16>): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.ClearPairing(liveRaw, user, controllerProviderId)
    }

    public unsafe func IsPilot(user: CPointer<Unit>, controllerProviderId: CPointer<UInt16>): CPointer<UInt16> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.IsPilot(liveRaw, user, controllerProviderId)
    }

    public unsafe func IsCopilot(user: CPointer<Unit>, controllerProviderId: CPointer<UInt16>): CPointer<UInt16> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.IsCopilot(liveRaw, user, controllerProviderId)
    }
}

@When[Windows_Gaming_Input_Preview == "on"]
@C
public struct RemappingButtonCategory {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: RemappingButtonCategory): Bool {
        return this.value == other.value
    }
    public operator func !=(other: RemappingButtonCategory): Bool {
        return this.value != other.value
    }
}

