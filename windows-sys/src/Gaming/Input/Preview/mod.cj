    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func FromGameController(controller: CPointer<Unit>): CPointer<Unit> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.FromGameController(__liveRaw, controller)
    }

    public unsafe func FromGameControllerProvider(provider: CPointer<Unit>): CPointer<Unit> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.FromGameControllerProvider(__liveRaw, provider)
    }

    public unsafe func PairPilotToCopilot(user: CPointer<Unit>, pilotControllerProviderId: CPointer<UInt16>, copilotControllerProviderId: CPointer<UInt16>): Unit {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        __vt.PairPilotToCopilot(__liveRaw, user, pilotControllerProviderId, copilotControllerProviderId)
    }

    public unsafe func ClearPairing(user: CPointer<Unit>, controllerProviderId: CPointer<UInt16>): Unit {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        __vt.ClearPairing(__liveRaw, user, controllerProviderId)
    }

    public unsafe func IsPilot(user: CPointer<Unit>, controllerProviderId: CPointer<UInt16>): CPointer<UInt16> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.IsPilot(__liveRaw, user, controllerProviderId)
    }

    public unsafe func IsCopilot(user: CPointer<Unit>, controllerProviderId: CPointer<UInt16>): CPointer<UInt16> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.IsCopilot(__liveRaw, user, controllerProviderId)
    }
}

