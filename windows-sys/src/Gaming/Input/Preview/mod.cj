    @When[Windows_System == "on"]
    public unsafe func ClearPairing(user: CPointer<Unit>, controllerProviderId: CPointer<Unit>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.ClearPairing(__liveRaw, user, controllerProviderId)
    }

    @When[Windows_System == "on"]
    public unsafe func IsPilot(user: CPointer<Unit>, controllerProviderId: CPointer<Unit>, result__: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.IsPilot(__liveRaw, user, controllerProviderId, result__)
    }

    @When[Windows_System == "on"]
    public unsafe func IsCopilot(user: CPointer<Unit>, controllerProviderId: CPointer<Unit>, result__: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.IsCopilot(__liveRaw, user, controllerProviderId, result__)
    }
}
