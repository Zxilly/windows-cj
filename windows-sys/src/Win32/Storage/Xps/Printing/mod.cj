                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func Close(): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.Close(liveRaw)
    }
}

