    public unsafe func CreateLun2(type_: Int32, ullSizeInBytes: UInt64, pDriveIdArray: CPointer<GUID>, lNumberOfDrives: Int32, pwszUnmaskingList: CPointer<UInt16>, pHints2: CPointer<VDS_HINTS2>, ppAsync: CPointer<CPointer<Unit>>): Int32 {
