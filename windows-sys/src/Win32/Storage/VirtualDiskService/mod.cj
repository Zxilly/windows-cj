        let __liveRaw = asRaw()
        return __vt.CreateLun2(__liveRaw, type_, ullSizeInBytes, pDriveIdArray, lNumberOfDrives, pwszUnmaskingList, pHints2, ppAsync)
    }

    public unsafe func QueryMaxLunCreateSize2(type_: Int32, pDriveIdArray: CPointer<GUID>, lNumberOfDrives: Int32, pHints2: CPointer<VDS_HINTS2>, pullMaxLunSize: CPointer<UInt64>): Int32 {
