@When[Windows_Win32_Storage_OfflineFiles == "on"]
public class IOfflineFilesConnectionInfo <: InterfaceWrapperBase & ComInterface {
    public init(raw: CPointer<Unit>) {
        super(raw)
    }

    protected init(raw: CPointer<Unit>, takeOwnership!: Bool, allowManualRelease!: Bool) {
        super(raw, takeOwnership: takeOwnership, allowManualRelease: allowManualRelease)
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IOfflineFilesConnectionInfo {
        IOfflineFilesConnectionInfo(raw, takeOwnership: true, allowManualRelease: false)
    }

    public static func viewOf(raw: CPointer<Unit>): IOfflineFilesConnectionInfo {
        IOfflineFilesConnectionInfo(raw, takeOwnership: false, allowManualRelease: false)
    }

    public static func iid(): GUID {
        return GUID(0xEFB23A09, 0xA867, 0x4BE8, 0x83, 0xA6, 0x86, 0x96, 0x9A, 0x7D, 0x08, 0x56)
    }

    public static func descriptor(): InterfaceDescriptor<IOfflineFilesConnectionInfo> {
        return InterfaceDescriptor<IOfflineFilesConnectionInfo>("IOfflineFilesConnectionInfo", IOfflineFilesConnectionInfo.iid(), takeIOfflineFilesConnectionInfoFromAbi, viewIOfflineFilesConnectionInfo)
    }

    public unsafe func vtbl(): IOfflineFilesConnectionInfoVtbl {
        readVtbl<IOfflineFilesConnectionInfoVtbl>(IOfflineFilesConnectionInfoVtbl())
    }

    public unsafe func GetConnectState(pConnectState: CPointer<Int32>, pOfflineReason: CPointer<Int32>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.GetConnectState(__liveRaw, pConnectState, pOfflineReason)
    }

    public unsafe func SetConnectState(hwndParent: CPointer<Unit>, dwFlags: UInt32, ConnectState: Int32): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.SetConnectState(__liveRaw, hwndParent, dwFlags, ConnectState)
    }

    public unsafe func TransitionOnline(hwndParent: CPointer<Unit>, dwFlags: UInt32): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.TransitionOnline(__liveRaw, hwndParent, dwFlags)
    }

    public unsafe func TransitionOffline(hwndParent: CPointer<Unit>, dwFlags: UInt32, bForceOpenFilesClosed: Int32, pbOpenFilesPreventedTransition: CPointer<Int32>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.TransitionOffline(__liveRaw, hwndParent, dwFlags, bForceOpenFilesClosed, pbOpenFilesPreventedTransition)
    }
