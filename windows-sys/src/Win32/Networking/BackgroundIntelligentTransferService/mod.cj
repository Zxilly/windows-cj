        let liveRaw = asRaw()
        return v.Skip(liveRaw, celt)
    }

    public unsafe func Reset(): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.Reset(liveRaw)
    }

    public unsafe func Clone(ppenum: CPointer<CPointer<Unit>>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.Clone(liveRaw, ppenum)
    }

    public unsafe func GetCount(puCount: CPointer<UInt32>): Int32 {
