    public var n_addrtype: Int16 = 0
    public var n_net: UInt32 = 0
    public init() {}
}

@When[Windows_Win32_Networking_WinSock == "on"]
public type socklen_t = Int32

@When[Windows_Win32_Networking_WinSock == "on"]
@C
public struct sockproto {
    public var sp_family: UInt16 = 0
    public var sp_protocol: UInt16 = 0
    public init() {}
}

@When[Windows_Win32_Networking_WinSock == "on"]
@C
public struct tcp_keepalive {
    public var onoff: UInt32 = 0
    public var keepalivetime: UInt32 = 0
    public var keepaliveinterval: UInt32 = 0
    public init() {}
}
