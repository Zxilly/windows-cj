public struct IUnknownVtbl {
    public var QueryInterface: CFunc<(CPointer<Unit>, CPointer<GUID>, CPointer<CPointer<Unit>>) -> Int32> = { _, _, _ => 0 }
    public var AddRef: CFunc<(CPointer<Unit>) -> UInt32> = { _ => 0 }
    public var Release: CFunc<(CPointer<Unit>) -> UInt32> = { _ => 0 }
    public init() {}
}

@When[Windows_Win32_System_Com == "on"]
func takeIUnknownFromAbi(raw: CPointer<Unit>): IUnknown {
    IUnknown.fromAbiTake(raw)
}

@When[Windows_Win32_System_Com == "on"]
func viewIUnknown(raw: CPointer<Unit>): IUnknown {
    IUnknown.viewOf(raw)
}

@When[Windows_Win32_System_Com == "on"]
public class IUnknown <: InterfaceWrapperBase & ComInterface {
    public init(raw: CPointer<Unit>) {
        super(raw)
    }

    protected init(raw: CPointer<Unit>, takeOwnership!: Bool, allowManualRelease!: Bool) {
        super(raw, takeOwnership: takeOwnership, allowManualRelease: allowManualRelease)
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IUnknown {
        IUnknown(raw, takeOwnership: true, allowManualRelease: false)
    }

    public static func viewOf(raw: CPointer<Unit>): IUnknown {
        IUnknown(raw, takeOwnership: false, allowManualRelease: false)
    }

    public static func iid(): GUID {
        return GUID(0x00000000, 0x0000, 0x0000, 0xC0, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x46)
    }

    public static func descriptor(): InterfaceDescriptor<IUnknown> {
        return InterfaceDescriptor<IUnknown>("IUnknown", IUnknown.iid(), takeIUnknownFromAbi, viewIUnknown)
    }

    public unsafe func vtbl(): IUnknownVtbl {
        readVtbl<IUnknownVtbl>(IUnknownVtbl())
    }

    public unsafe func QueryInterface(riid: CPointer<GUID>, ppvObject: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.QueryInterface(__liveRaw, riid, ppvObject)
    }

    public unsafe func AddRef(): UInt32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.AddRef(__liveRaw)
    }

    public unsafe func Release(): UInt32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Release(__liveRaw)
    }
}

