@When[Windows_Win32_UI_Shell == "on"]
public struct SHGSI_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: SHGSI_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SHGSI_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: SHGSI_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: SHGSI_FLAGS): SHGSI_FLAGS {
        return SHGSI_FLAGS(this.value | other.value)
    }
    public operator func &(other: SHGSI_FLAGS): SHGSI_FLAGS {
        return SHGSI_FLAGS(this.value & other.value)
    }
    public operator func !(): SHGSI_FLAGS {
        return SHGSI_FLAGS(!this.value)
    }
}

