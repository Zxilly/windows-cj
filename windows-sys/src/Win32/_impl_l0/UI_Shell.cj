public struct TBPFLAG {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: TBPFLAG): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TBPFLAG): Bool {
        return this.value != other.value
    }

    public func contains(other: TBPFLAG): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: TBPFLAG): TBPFLAG {
        return TBPFLAG(this.value | other.value)
    }
    public operator func &(other: TBPFLAG): TBPFLAG {
        return TBPFLAG(this.value & other.value)
    }
    public operator func !(): TBPFLAG {
        return TBPFLAG(!this.value)
    }
}

