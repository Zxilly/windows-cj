public struct RefreshConstants {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: RefreshConstants): Bool {
        return this.value == other.value
    }
    public operator func !=(other: RefreshConstants): Bool {
        return this.value != other.value
    }
}

@When[Windows_Win32_UI_Shell == "on"]
