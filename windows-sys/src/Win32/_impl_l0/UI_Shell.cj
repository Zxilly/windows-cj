@When[Windows_Win32_UI_Shell == "on"]
// packed(1)
@C
public struct DATABLOCK_HEADER {
    public var _raw: VArray<UInt8, $8> = VArray<UInt8, $8>(repeat: 0u8)

    public mut prop cbSize: UInt32 {
        get() {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                return packedReadUInt32(base, 0)
            }
        }
        set(val) {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                packedWriteUInt32(base, 0, val)
                _raw = rawStorage
            }
        }
    }

    public mut prop dwSignature: UInt32 {
        get() {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                return packedReadUInt32(base, 4)
            }
        }
        set(val) {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                packedWriteUInt32(base, 4, val)
                _raw = rawStorage
            }
        }
    }
    public init() {}
}

