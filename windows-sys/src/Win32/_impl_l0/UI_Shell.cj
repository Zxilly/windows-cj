@When[Windows_Win32_UI_Shell == "on"]
public struct SCALE_CHANGE_FLAGS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: SCALE_CHANGE_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SCALE_CHANGE_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: SCALE_CHANGE_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: SCALE_CHANGE_FLAGS): SCALE_CHANGE_FLAGS {
        return SCALE_CHANGE_FLAGS(this.value | other.value)
    }
    public operator func &(other: SCALE_CHANGE_FLAGS): SCALE_CHANGE_FLAGS {
        return SCALE_CHANGE_FLAGS(this.value & other.value)
    }
    public operator func !(): SCALE_CHANGE_FLAGS {
        return SCALE_CHANGE_FLAGS(!this.value)
    }
}

@When[Windows_Win32_UI_Shell == "on"]
public let SCALE_CHANGE_FLAGS_SCF_VALUE_NONE: SCALE_CHANGE_FLAGS = SCALE_CHANGE_FLAGS(0)

