@When[Windows_Win32_UI_Shell == "on"]
public struct HLNF {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: HLNF): Bool {
        return this.value == other.value
    }
    public operator func !=(other: HLNF): Bool {
        return this.value != other.value
    }

    public func contains(other: HLNF): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: HLNF): HLNF {
        return HLNF(this.value | other.value)
    }
    public operator func &(other: HLNF): HLNF {
        return HLNF(this.value & other.value)
    }
    public operator func !(): HLNF {
        return HLNF(!this.value)
    }
}

