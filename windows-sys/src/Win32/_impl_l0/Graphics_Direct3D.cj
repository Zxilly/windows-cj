@When[Windows_Win32_Graphics_Direct3D == "on"]
// NOTE: union represented as size-equivalent VArray slot with typed `mut prop` accessors
// (Cangjie paradigm: `@C struct` cannot host a union variant; ABI footprint is preserved)
@C
public struct D3D_VERSION_NUMBER {
    public var _raw: VArray<UInt64, $1> = VArray<UInt64, $1>(repeat: 0)

    public mut prop version: UInt64 {
        get() {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                return unionReadUInt64(base, 0)
            }
        }
        set(val) {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                unionWriteUInt64(base, 0, val)
                _raw = rawStorage
            }
        }
    }

    public mut prop versionParts: VArray<UInt16, $4> {
        get() {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<VArray<UInt16, $4>>(p)
                return ptr.read()
            }
        }
        set(val) {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<VArray<UInt16, $4>>(p)
                ptr.write(val)
                _raw = rawStorage
            }
        }
    }
    public init() {}
}

