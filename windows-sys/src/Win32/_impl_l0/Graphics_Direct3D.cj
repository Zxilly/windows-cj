public struct D3D_SHADER_CACHE_TARGET_FLAGS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: D3D_SHADER_CACHE_TARGET_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: D3D_SHADER_CACHE_TARGET_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: D3D_SHADER_CACHE_TARGET_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: D3D_SHADER_CACHE_TARGET_FLAGS): D3D_SHADER_CACHE_TARGET_FLAGS {
        return D3D_SHADER_CACHE_TARGET_FLAGS(this.value | other.value)
    }
    public operator func &(other: D3D_SHADER_CACHE_TARGET_FLAGS): D3D_SHADER_CACHE_TARGET_FLAGS {
        return D3D_SHADER_CACHE_TARGET_FLAGS(this.value & other.value)
    }
    public operator func !(): D3D_SHADER_CACHE_TARGET_FLAGS {
        return D3D_SHADER_CACHE_TARGET_FLAGS(!this.value)
    }
}

