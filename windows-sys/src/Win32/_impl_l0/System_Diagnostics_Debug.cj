public struct FORMAT_MESSAGE_OPTIONS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: FORMAT_MESSAGE_OPTIONS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: FORMAT_MESSAGE_OPTIONS): Bool {
        return this.value != other.value
    }

    public func contains(other: FORMAT_MESSAGE_OPTIONS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: FORMAT_MESSAGE_OPTIONS): FORMAT_MESSAGE_OPTIONS {
        return FORMAT_MESSAGE_OPTIONS(this.value | other.value)
    }
    public operator func &(other: FORMAT_MESSAGE_OPTIONS): FORMAT_MESSAGE_OPTIONS {
        return FORMAT_MESSAGE_OPTIONS(this.value & other.value)
    }
    public operator func !(): FORMAT_MESSAGE_OPTIONS {
        return FORMAT_MESSAGE_OPTIONS(!this.value)
    }
}

