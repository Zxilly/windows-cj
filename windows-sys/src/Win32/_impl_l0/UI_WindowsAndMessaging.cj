@When[Windows_Win32_UI_WindowsAndMessaging == "on"]
public struct WNDCLASS_STYLES {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: WNDCLASS_STYLES): Bool {
        return this.value == other.value
    }
    public operator func !=(other: WNDCLASS_STYLES): Bool {
        return this.value != other.value
    }

    public func contains(other: WNDCLASS_STYLES): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: WNDCLASS_STYLES): WNDCLASS_STYLES {
        return WNDCLASS_STYLES(this.value | other.value)
    }
    public operator func &(other: WNDCLASS_STYLES): WNDCLASS_STYLES {
        return WNDCLASS_STYLES(this.value & other.value)
    }
    public operator func !(): WNDCLASS_STYLES {
        return WNDCLASS_STYLES(!this.value)
    }
}

