@When[Windows_Win32_Security_Cryptography == "on"]
public struct NCRYPT_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: NCRYPT_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: NCRYPT_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: NCRYPT_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: NCRYPT_FLAGS): NCRYPT_FLAGS {
        return NCRYPT_FLAGS(this.value | other.value)
    }
    public operator func &(other: NCRYPT_FLAGS): NCRYPT_FLAGS {
        return NCRYPT_FLAGS(this.value & other.value)
    }
    public operator func !(): NCRYPT_FLAGS {
        return NCRYPT_FLAGS(!this.value)
    }
}

