@When[Windows_Win32_Security_Cryptography == "on"]
public struct CRYPT_KEY_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: CRYPT_KEY_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: CRYPT_KEY_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: CRYPT_KEY_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: CRYPT_KEY_FLAGS): CRYPT_KEY_FLAGS {
        return CRYPT_KEY_FLAGS(this.value | other.value)
    }
    public operator func &(other: CRYPT_KEY_FLAGS): CRYPT_KEY_FLAGS {
        return CRYPT_KEY_FLAGS(this.value & other.value)
    }
    public operator func !(): CRYPT_KEY_FLAGS {
        return CRYPT_KEY_FLAGS(!this.value)
    }
}

