@When[Windows_Win32_UI_Controls == "on"]
public struct HDI_MASK {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: HDI_MASK): Bool {
        return this.value == other.value
    }
    public operator func !=(other: HDI_MASK): Bool {
        return this.value != other.value
    }

    public func contains(other: HDI_MASK): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: HDI_MASK): HDI_MASK {
        return HDI_MASK(this.value | other.value)
    }
    public operator func &(other: HDI_MASK): HDI_MASK {
        return HDI_MASK(this.value & other.value)
    }
    public operator func !(): HDI_MASK {
        return HDI_MASK(!this.value)
    }
}

