    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: DLG_DIR_LIST_FILE_TYPE): Bool {
        return this.value == other.value
    }
    public operator func !=(other: DLG_DIR_LIST_FILE_TYPE): Bool {
        return this.value != other.value
    }

    public func contains(other: DLG_DIR_LIST_FILE_TYPE): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: DLG_DIR_LIST_FILE_TYPE): DLG_DIR_LIST_FILE_TYPE {
        return DLG_DIR_LIST_FILE_TYPE(this.value | other.value)
    }
    public operator func &(other: DLG_DIR_LIST_FILE_TYPE): DLG_DIR_LIST_FILE_TYPE {
        return DLG_DIR_LIST_FILE_TYPE(this.value & other.value)
    }
    public operator func !(): DLG_DIR_LIST_FILE_TYPE {
        return DLG_DIR_LIST_FILE_TYPE(!this.value)
    }
}

