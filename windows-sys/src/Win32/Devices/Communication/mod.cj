    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: PURGE_COMM_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PURGE_COMM_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: PURGE_COMM_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: PURGE_COMM_FLAGS): PURGE_COMM_FLAGS {
        return PURGE_COMM_FLAGS(this.value | other.value)
    }
    public operator func &(other: PURGE_COMM_FLAGS): PURGE_COMM_FLAGS {
        return PURGE_COMM_FLAGS(this.value & other.value)
    }
    public operator func !(): PURGE_COMM_FLAGS {
        return PURGE_COMM_FLAGS(!this.value)
    }
}

@When[Windows_Win32_Devices_Communication == "on"]
public let PURGE_RXABORT: PURGE_COMM_FLAGS = PURGE_COMM_FLAGS(2)

@When[Windows_Win32_Devices_Communication == "on"]
public let PURGE_RXCLEAR: PURGE_COMM_FLAGS = PURGE_COMM_FLAGS(8)

@When[Windows_Win32_Devices_Communication == "on"]
public let PURGE_TXABORT: PURGE_COMM_FLAGS = PURGE_COMM_FLAGS(1)

@When[Windows_Win32_Devices_Communication == "on"]
public let PURGE_TXCLEAR: PURGE_COMM_FLAGS = PURGE_COMM_FLAGS(4)

