@When[Windows_Win32_Devices_Usb == "on"]
public struct USB_CONNECTION_STATUS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: USB_CONNECTION_STATUS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: USB_CONNECTION_STATUS): Bool {
        return this.value != other.value
    }
}

