public struct SP_COPY_STYLE {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: SP_COPY_STYLE): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SP_COPY_STYLE): Bool {
        return this.value != other.value
    }

    public func contains(other: SP_COPY_STYLE): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: SP_COPY_STYLE): SP_COPY_STYLE {
        return SP_COPY_STYLE(this.value | other.value)
    }
    public operator func &(other: SP_COPY_STYLE): SP_COPY_STYLE {
        return SP_COPY_STYLE(this.value & other.value)
    }
    public operator func !(): SP_COPY_STYLE {
        return SP_COPY_STYLE(!this.value)
    }
}

