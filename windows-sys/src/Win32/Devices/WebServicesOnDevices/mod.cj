    func WSDXMLGetValueFromAny(pszNamespace: CPointer<UInt16>, pszName: CPointer<UInt16>, pAny: CPointer<WSDXML_ELEMENT>, ppszValue: CPointer<CPointer<UInt16>>): Int32
}

