@When[Windows_Win32_Security_Tpm == "on"]
@C
public struct TPMVSC_ATTESTATION_TYPE {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: TPMVSC_ATTESTATION_TYPE): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TPMVSC_ATTESTATION_TYPE): Bool {
        return this.value != other.value
    }
}

@When[Windows_Win32_Security_Tpm == "on"]
public let TPMVSC_ATTESTATION_NONE: TPMVSC_ATTESTATION_TYPE = TPMVSC_ATTESTATION_TYPE(0)

