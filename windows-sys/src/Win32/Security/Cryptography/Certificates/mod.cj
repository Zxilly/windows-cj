@When[Windows_Win32_Security_Cryptography_Certificates == "on"]
func takeIEnrollFromAbi(raw: CPointer<Unit>): IEnroll {
    IEnroll.fromAbiTake(raw)
}

@When[Windows_Win32_Security_Cryptography_Certificates == "on"]
func viewIEnroll(raw: CPointer<Unit>): IEnroll {
    IEnroll(raw)
}

@When[Windows_Win32_Security_Cryptography_Certificates == "on"]
public class IEnroll <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IEnroll {
        IEnroll(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IEnroll {
        IEnroll(raw)
    }

    public static func iid(): GUID {
        return GUID(0xACAA7838, 0x4585, 0x11D1, 0xAB, 0x57, 0x00, 0xC0, 0x4F, 0xC2, 0x95, 0xE1)
    }

    public static func descriptor(): InterfaceDescriptor<IEnroll> {
        return InterfaceDescriptor<IEnroll>("IEnroll", IEnroll.iid(), takeIEnrollFromAbi, viewIEnroll)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IEnrollVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IEnrollVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IEnrollVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

