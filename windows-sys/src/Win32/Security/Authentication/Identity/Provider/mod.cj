        return this.value == other.value
    }
    public operator func !=(other: IdentityUpdateEvent): Bool {
        return this.value != other.value
    }

    public func contains(other: IdentityUpdateEvent): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: IdentityUpdateEvent): IdentityUpdateEvent {
        return IdentityUpdateEvent(this.value | other.value)
    }
    public operator func &(other: IdentityUpdateEvent): IdentityUpdateEvent {
        return IdentityUpdateEvent(this.value & other.value)
    }
    public operator func !(): IdentityUpdateEvent {
        return IdentityUpdateEvent(!this.value)
    }
}

