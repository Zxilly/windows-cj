            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func GetPasswordCredentials(pluginInput: CPointer<UInt16>, domainName: CPointer<CPointer<UInt16>>, username: CPointer<CPointer<UInt16>>, password: CPointer<CPointer<UInt16>>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetPasswordCredentials(liveRaw, pluginInput, domainName, username, password)
    }
}

