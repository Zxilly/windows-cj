@When[Windows_Win32_Graphics_Direct3D11 == "on"]
public struct D3D11_RESOURCE_MISC_FLAG {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: D3D11_RESOURCE_MISC_FLAG): Bool {
        return this.value == other.value
    }
    public operator func !=(other: D3D11_RESOURCE_MISC_FLAG): Bool {
        return this.value != other.value
    }

    public func contains(other: D3D11_RESOURCE_MISC_FLAG): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: D3D11_RESOURCE_MISC_FLAG): D3D11_RESOURCE_MISC_FLAG {
        return D3D11_RESOURCE_MISC_FLAG(this.value | other.value)
    }
    public operator func &(other: D3D11_RESOURCE_MISC_FLAG): D3D11_RESOURCE_MISC_FLAG {
        return D3D11_RESOURCE_MISC_FLAG(this.value & other.value)
    }
    public operator func !(): D3D11_RESOURCE_MISC_FLAG {
        return D3D11_RESOURCE_MISC_FLAG(!this.value)
    }
