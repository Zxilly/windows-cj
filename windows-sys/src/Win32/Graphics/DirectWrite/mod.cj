        return this.value == other.value
    }
    public operator func !=(other: DWRITE_SCRIPT_SHAPES): Bool {
        return this.value != other.value
    }

    public func contains(other: DWRITE_SCRIPT_SHAPES): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: DWRITE_SCRIPT_SHAPES): DWRITE_SCRIPT_SHAPES {
        return DWRITE_SCRIPT_SHAPES(this.value | other.value)
    }
    public operator func &(other: DWRITE_SCRIPT_SHAPES): DWRITE_SCRIPT_SHAPES {
        return DWRITE_SCRIPT_SHAPES(this.value & other.value)
    }
