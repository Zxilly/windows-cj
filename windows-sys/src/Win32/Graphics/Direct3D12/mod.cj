public struct D3D12_FENCE_FLAGS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: D3D12_FENCE_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: D3D12_FENCE_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: D3D12_FENCE_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: D3D12_FENCE_FLAGS): D3D12_FENCE_FLAGS {
        return D3D12_FENCE_FLAGS(this.value | other.value)
    }
    public operator func &(other: D3D12_FENCE_FLAGS): D3D12_FENCE_FLAGS {
        return D3D12_FENCE_FLAGS(this.value & other.value)
    }
    public operator func !(): D3D12_FENCE_FLAGS {
        return D3D12_FENCE_FLAGS(!this.value)
    }
}

