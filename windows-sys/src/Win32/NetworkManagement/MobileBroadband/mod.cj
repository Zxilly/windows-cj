        let __liveRaw = asRaw()
        return __vt.InterfaceID(__liveRaw, InterfaceID)
    }

    public unsafe func Connect(connectionMode: Int32, strProfile: CPointer<UInt16>, requestID: CPointer<UInt32>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Connect(__liveRaw, connectionMode, strProfile, requestID)
    }

    public unsafe func Disconnect(requestID: CPointer<UInt32>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Disconnect(__liveRaw, requestID)
    }

    public unsafe func GetConnectionState(ConnectionState: CPointer<Int32>, ProfileName: CPointer<CPointer<UInt16>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.GetConnectionState(__liveRaw, ConnectionState, ProfileName)
