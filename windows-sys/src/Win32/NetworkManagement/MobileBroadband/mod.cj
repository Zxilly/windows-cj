        super(raw, takeOwnership: takeOwnership, allowManualRelease: allowManualRelease)
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IMbnConnection {
        IMbnConnection(raw, takeOwnership: true, allowManualRelease: false)
    }

    public static func viewOf(raw: CPointer<Unit>): IMbnConnection {
        IMbnConnection(raw, takeOwnership: false, allowManualRelease: false)
    }

    public static func iid(): GUID {
        return GUID(0xDCBBBAB6, 0x200D, 0x4BBB, 0xAA, 0xEE, 0x33, 0x8E, 0x36, 0x8A, 0xF6, 0xFA)
    }

    public static func descriptor(): InterfaceDescriptor<IMbnConnection> {
        return InterfaceDescriptor<IMbnConnection>("IMbnConnection", IMbnConnection.iid(), takeIMbnConnectionFromAbi, viewIMbnConnection)
    }

    public unsafe func vtbl(): IMbnConnectionVtbl {
        readVtbl<IMbnConnectionVtbl>(IMbnConnectionVtbl())
    }

    public unsafe func ConnectionID(ConnectionID: CPointer<CPointer<UInt16>>): Int32 {
