@When[Windows_Win32_UI_Input_GameInput == "on"]
@C
public struct GameInputMouseButtons {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: GameInputMouseButtons): Bool {
        return this.value == other.value
    }
    public operator func !=(other: GameInputMouseButtons): Bool {
        return this.value != other.value
    }

    public func contains(other: GameInputMouseButtons): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: GameInputMouseButtons): GameInputMouseButtons {
        return GameInputMouseButtons(this.value | other.value)
    }
    public operator func &(other: GameInputMouseButtons): GameInputMouseButtons {
        return GameInputMouseButtons(this.value & other.value)
    }
    public operator func !(): GameInputMouseButtons {
        return GameInputMouseButtons(!this.value)
    }
}

