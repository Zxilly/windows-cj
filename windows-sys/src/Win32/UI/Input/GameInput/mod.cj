        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IGameInputReading {
        IGameInputReading(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IGameInputReading {
        IGameInputReading(raw)
    }

    public static func iid(): GUID {
        return GUID(0x2156947A, 0xE1FA, 0x4DE0, 0xA3, 0x0B, 0xD8, 0x12, 0x93, 0x1D, 0xBD, 0x8D)
    }

    public static func descriptor(): InterfaceDescriptor<IGameInputReading> {
        return InterfaceDescriptor<IGameInputReading>("IGameInputReading", IGameInputReading.iid(), takeIGameInputReadingFromAbi, viewIGameInputReading)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IGameInputReadingVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IGameInputReadingVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IGameInputReadingVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

