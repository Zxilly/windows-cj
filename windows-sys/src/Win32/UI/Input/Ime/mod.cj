@When[Windows_Win32_UI_Input_Ime == "on"]
func takeIActiveIMMIMEFromAbi(raw: CPointer<Unit>): IActiveIMMIME {
    IActiveIMMIME.fromAbiTake(raw)
}

@When[Windows_Win32_UI_Input_Ime == "on"]
func viewIActiveIMMIME(raw: CPointer<Unit>): IActiveIMMIME {
    IActiveIMMIME(raw)
}

@When[Windows_Win32_UI_Input_Ime == "on"]
public class IActiveIMMIME <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IActiveIMMIME {
        IActiveIMMIME(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IActiveIMMIME {
        IActiveIMMIME(raw)
    }

    public static func iid(): GUID {
        return GUID(0x08C03411, 0xF96B, 0x11D0, 0xA4, 0x75, 0x00, 0xAA, 0x00, 0x6B, 0xCC, 0x59)
    }

    public static func descriptor(): InterfaceDescriptor<IActiveIMMIME> {
        return InterfaceDescriptor<IActiveIMMIME>("IActiveIMMIME", IActiveIMMIME.iid(), takeIActiveIMMIMEFromAbi, viewIActiveIMMIME)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IActiveIMMIMEVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IActiveIMMIMEVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IActiveIMMIMEVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
