func takeIActiveIMMAppFromAbi(raw: CPointer<Unit>): IActiveIMMApp {
    IActiveIMMApp.fromAbiTake(raw)
}

@When[Windows_Win32_UI_Input_Ime == "on"]
func viewIActiveIMMApp(raw: CPointer<Unit>): IActiveIMMApp {
    IActiveIMMApp(raw)
}

@When[Windows_Win32_UI_Input_Ime == "on"]
public class IActiveIMMApp <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IActiveIMMApp {
        IActiveIMMApp(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IActiveIMMApp {
        IActiveIMMApp(raw)
    }

    public static func iid(): GUID {
        return GUID(0x08C0E040, 0x62D1, 0x11D1, 0x93, 0x26, 0x00, 0x60, 0xB0, 0x67, 0xB8, 0x6E)
    }

    public static func descriptor(): InterfaceDescriptor<IActiveIMMApp> {
        return InterfaceDescriptor<IActiveIMMApp>("IActiveIMMApp", IActiveIMMApp.iid(), takeIActiveIMMAppFromAbi, viewIActiveIMMApp)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IActiveIMMAppVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IActiveIMMAppVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IActiveIMMAppVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

