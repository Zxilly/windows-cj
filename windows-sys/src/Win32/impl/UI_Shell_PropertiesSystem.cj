    }

    public unsafe func FormatForDisplay(fmtid: CPointer<GUID>, pid: UInt32, ppropvar: CPointer<PROPVARIANT>, puiff: PROPERTYUI_FORMAT_FLAGS, pwszText: CPointer<UInt16>, cchText: UInt32): Int32 {
