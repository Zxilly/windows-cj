@When[Windows_Win32_UI_Shell_PropertiesSystem == "on"]
public class IPropertyUI <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IPropertyUI {
        IPropertyUI(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IPropertyUI {
        IPropertyUI(raw)
    }

    public static func iid(): GUID {
        return GUID(0x757A7D9F, 0x919A, 0x4118, 0x99, 0xD7, 0xDB, 0xB2, 0x08, 0xC8, 0xCC, 0x66)
    }

    public static func descriptor(): InterfaceDescriptor<IPropertyUI> {
        return InterfaceDescriptor<IPropertyUI>("IPropertyUI", IPropertyUI.iid(), takeIPropertyUIFromAbi, viewIPropertyUI)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IPropertyUIVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IPropertyUIVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IPropertyUIVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func ParsePropertyName(pszName: CPointer<UInt16>, pfmtid: CPointer<GUID>, ppid: CPointer<UInt32>, pchEaten: CPointer<UInt32>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.ParsePropertyName(liveRaw, pszName, pfmtid, ppid, pchEaten)
    }

    public unsafe func GetCannonicalName(fmtid: CPointer<GUID>, pid: UInt32, pwszText: CPointer<UInt16>, cchText: UInt32): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetCannonicalName(liveRaw, fmtid, pid, pwszText, cchText)
    }

    public unsafe func GetDisplayName(fmtid: CPointer<GUID>, pid: UInt32, flags: PROPERTYUI_NAME_FLAGS, pwszText: CPointer<UInt16>, cchText: UInt32): Int32 {
        let v = vtbl()
