@C
public struct _PERSIST_SPROPSTORE_FLAGS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: _PERSIST_SPROPSTORE_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: _PERSIST_SPROPSTORE_FLAGS): Bool {
        return this.value != other.value
    }
}

