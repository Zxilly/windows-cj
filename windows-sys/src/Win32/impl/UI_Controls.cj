@C
public struct TOOLTIP_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: TOOLTIP_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TOOLTIP_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: TOOLTIP_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: TOOLTIP_FLAGS): TOOLTIP_FLAGS {
        return TOOLTIP_FLAGS(this.value | other.value)
    }
    public operator func &(other: TOOLTIP_FLAGS): TOOLTIP_FLAGS {
        return TOOLTIP_FLAGS(this.value & other.value)
    }
    public operator func !(): TOOLTIP_FLAGS {
        return TOOLTIP_FLAGS(!this.value)
    }
}

