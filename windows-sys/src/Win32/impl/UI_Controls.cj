@When[Windows_Win32_UI_Controls == "on"]
@C
public struct COMBOBOX_EX_ITEM_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: COMBOBOX_EX_ITEM_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: COMBOBOX_EX_ITEM_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: COMBOBOX_EX_ITEM_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: COMBOBOX_EX_ITEM_FLAGS): COMBOBOX_EX_ITEM_FLAGS {
        return COMBOBOX_EX_ITEM_FLAGS(this.value | other.value)
    }
    public operator func &(other: COMBOBOX_EX_ITEM_FLAGS): COMBOBOX_EX_ITEM_FLAGS {
