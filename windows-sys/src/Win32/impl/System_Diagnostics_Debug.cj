@When[Windows_Win32_System_Diagnostics_Debug == "on"]
@C
public struct CONTEXT_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: CONTEXT_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: CONTEXT_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: CONTEXT_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: CONTEXT_FLAGS): CONTEXT_FLAGS {
        return CONTEXT_FLAGS(this.value | other.value)
    }
    public operator func &(other: CONTEXT_FLAGS): CONTEXT_FLAGS {
        return CONTEXT_FLAGS(this.value & other.value)
    }
    public operator func !(): CONTEXT_FLAGS {
        return CONTEXT_FLAGS(!this.value)
    }
}

