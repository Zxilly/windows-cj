@When[Windows_Win32_System_Com == "on"]
@C
public struct IDLFLAGS {
    public var value: UInt16 = 0

    public init() {}

    public init(value: UInt16) {
        this.value = value
    }

    public operator func ==(other: IDLFLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: IDLFLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: IDLFLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: IDLFLAGS): IDLFLAGS {
        return IDLFLAGS(this.value | other.value)
    }
    public operator func &(other: IDLFLAGS): IDLFLAGS {
        return IDLFLAGS(this.value & other.value)
    }
    public operator func !(): IDLFLAGS {
        return IDLFLAGS(!this.value)
    }
}

