@C
public struct IMPLTYPEFLAGS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: IMPLTYPEFLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: IMPLTYPEFLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: IMPLTYPEFLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: IMPLTYPEFLAGS): IMPLTYPEFLAGS {
        return IMPLTYPEFLAGS(this.value | other.value)
    }
    public operator func &(other: IMPLTYPEFLAGS): IMPLTYPEFLAGS {
        return IMPLTYPEFLAGS(this.value & other.value)
    }
    public operator func !(): IMPLTYPEFLAGS {
        return IMPLTYPEFLAGS(!this.value)
    }
}

