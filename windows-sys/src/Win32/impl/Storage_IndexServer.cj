            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func GetImageInfo(imageInfo: CPointer<IMAGE_INFO>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetImageInfo(liveRaw, imageInfo)
    }

    public unsafe func GetPixelsForImage(scalingFactor: Float32, sourceRect: CPointer<Win32_Foundation.RECT>, pixelBufferSize: UInt32, pixelBuffer: CPointer<UInt8>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetPixelsForImage(liveRaw, scalingFactor, sourceRect, pixelBufferSize, pixelBuffer)
    }
}

