@When[Windows_Win32_Graphics_GdiPlus == "on"]
public class IImageBytes <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): IImageBytes {
        IImageBytes(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): IImageBytes {
        IImageBytes(raw)
    }

    public static func iid(): GUID {
        return GUID(0x025D1823, 0x6C7D, 0x447B, 0xBB, 0xDB, 0xA3, 0xCB, 0xC3, 0xDF, 0xA2, 0xFC)
    }

    public static func descriptor(): InterfaceDescriptor<IImageBytes> {
        return InterfaceDescriptor<IImageBytes>("IImageBytes", IImageBytes.iid(), takeIImageBytesFromAbi, viewIImageBytes)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): IImageBytesVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IImageBytesVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IImageBytesVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func CountBytes(pcb: CPointer<UInt32>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.CountBytes(liveRaw, pcb)
    }

    public unsafe func LockBytes(cb: UInt32, ulOffset: UInt32, ppvBytes: CPointer<CPointer<Unit>>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.LockBytes(liveRaw, cb, ulOffset, ppvBytes)
    }

    public unsafe func UnlockBytes(pvBytes: CPointer<Unit>, cb: UInt32, ulOffset: UInt32): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.UnlockBytes(liveRaw, pvBytes, cb, ulOffset)
