public struct VAR_CHANGE_FLAGS {
    public var value: UInt16 = 0

    public init() {}

    public init(value: UInt16) {
        this.value = value
    }

    public operator func ==(other: VAR_CHANGE_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: VAR_CHANGE_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: VAR_CHANGE_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: VAR_CHANGE_FLAGS): VAR_CHANGE_FLAGS {
        return VAR_CHANGE_FLAGS(this.value | other.value)
    }
    public operator func &(other: VAR_CHANGE_FLAGS): VAR_CHANGE_FLAGS {
        return VAR_CHANGE_FLAGS(this.value & other.value)
    }
    public operator func !(): VAR_CHANGE_FLAGS {
        return VAR_CHANGE_FLAGS(!this.value)
    }
}

