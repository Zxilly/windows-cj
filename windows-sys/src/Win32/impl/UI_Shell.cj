@When[Windows_Win32_UI_Shell == "on"]
public class DFConstraint <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): DFConstraint {
        DFConstraint(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): DFConstraint {
        DFConstraint(raw)
    }

    public static func iid(): GUID {
        return GUID(0x4A3DF050, 0x23BD, 0x11D2, 0x93, 0x9F, 0x00, 0xA0, 0xC9, 0x1E, 0xED, 0xBA)
    }

    public static func descriptor(): InterfaceDescriptor<DFConstraint> {
        return InterfaceDescriptor<DFConstraint>("DFConstraint", DFConstraint.iid(), IDispatch.iid(), takeDFConstraintFromAbi, viewDFConstraint)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): DFConstraintVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return DFConstraintVtbl()
