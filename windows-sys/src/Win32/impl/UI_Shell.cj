    Folder.fromAbiTake(raw)
}

@When[Windows_Win32_UI_Shell == "on"]
func viewFolder(raw: CPointer<Unit>): Folder {
    Folder(raw)
}

@When[Windows_Win32_UI_Shell == "on"]
public class Folder <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsHandle_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>) {
        this.raw_ = raw
        this.ownsHandle_ = false
    }

    private init(raw: CPointer<Unit>, takeOwnership!: Bool) {
        this.raw_ = raw
        this.ownsHandle_ = takeOwnership
    }

    public static func fromAbiTake(raw: CPointer<Unit>): Folder {
        Folder(raw, takeOwnership: true)
    }

    public static func viewOf(raw: CPointer<Unit>): Folder {
        Folder(raw)
    }

    public static func iid(): GUID {
        return GUID(0xBBCBDE60, 0xC3FF, 0x11CE, 0x83, 0x50, 0x44, 0x45, 0x53, 0x54, 0x00, 0x00)
    }

    public static func descriptor(): InterfaceDescriptor<Folder> {
        return InterfaceDescriptor<Folder>("Folder", Folder.iid(), IDispatch.iid(), takeFolderFromAbi, viewFolder)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): FolderVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return FolderVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<FolderVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func Title(pbs: CPointer<CPointer<UInt16>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Title(__liveRaw, pbs)
    }

    public unsafe func Application(ppid: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Application(__liveRaw, ppid)
    }

    public unsafe func Parent(ppid: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Parent(__liveRaw, ppid)
    }

    public unsafe func ParentFolder(ppsf: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.ParentFolder(__liveRaw, ppsf)
    }

    public unsafe func Items(ppid: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Items(__liveRaw, ppid)
    }

    public unsafe func ParseName(bName: CPointer<UInt16>, ppid: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.ParseName(__liveRaw, bName, ppid)
    }

    public unsafe func NewFolder(bName: CPointer<UInt16>, vOptions: VARIANT): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.NewFolder(__liveRaw, bName, vOptions)
    }

    public unsafe func MoveHere(vItem: VARIANT, vOptions: VARIANT): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.MoveHere(__liveRaw, vItem, vOptions)
    }

    public unsafe func CopyHere(vItem: VARIANT, vOptions: VARIANT): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.CopyHere(__liveRaw, vItem, vOptions)
    }

    public unsafe func GetDetailsOf(vItem: VARIANT, iColumn: Int32, pbs: CPointer<CPointer<UInt16>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.GetDetailsOf(__liveRaw, vItem, iColumn, pbs)
    }
}

