@When[Windows_Win32_System_Console == "on"]
@C
public struct STD_HANDLE {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: STD_HANDLE): Bool {
        return this.value == other.value
    }
    public operator func !=(other: STD_HANDLE): Bool {
        return this.value != other.value
    }
}

@When[Windows_Win32_System_Console == "on"]
public let STD_INPUT_HANDLE: STD_HANDLE = STD_HANDLE(4294967286)

