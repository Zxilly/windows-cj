@C
public struct OUTPUT_STATE {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: OUTPUT_STATE): Bool {
        return this.value == other.value
    }
    public operator func !=(other: OUTPUT_STATE): Bool {
        return this.value != other.value
    }

    public func contains(other: OUTPUT_STATE): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: OUTPUT_STATE): OUTPUT_STATE {
        return OUTPUT_STATE(this.value | other.value)
    }
    public operator func &(other: OUTPUT_STATE): OUTPUT_STATE {
        return OUTPUT_STATE(this.value & other.value)
    }
    public operator func !(): OUTPUT_STATE {
        return OUTPUT_STATE(!this.value)
    }
}

