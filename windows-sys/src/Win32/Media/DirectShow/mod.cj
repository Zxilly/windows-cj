        return this.value == other.value
    }
    public operator func !=(other: REG_PINFLAG): Bool {
        return this.value != other.value
    }

    public func contains(other: REG_PINFLAG): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: REG_PINFLAG): REG_PINFLAG {
        return REG_PINFLAG(this.value | other.value)
    }
    public operator func &(other: REG_PINFLAG): REG_PINFLAG {
        return REG_PINFLAG(this.value & other.value)
    }
    public operator func !(): REG_PINFLAG {
        return REG_PINFLAG(!this.value)
    }
}

