    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func GetXMLResult(Options: SPXMLRESULTOPTIONS, pResult: CPointer<CPointer<UInt16>>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetXMLResult(liveRaw, Options, pResult)
    }

    public unsafe func GetXMLErrorInfo(LineNumber: CPointer<Int32>, ScriptLine: CPointer<CPointer<UInt16>>, Source: CPointer<CPointer<UInt16>>, Description: CPointer<CPointer<UInt16>>, ResultCode: CPointer<Int32>, IsError: CPointer<Win32_Foundation.VARIANT_BOOL>): Int32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetXMLErrorInfo(liveRaw, LineNumber, ScriptLine, Source, Description, ResultCode, IsError)
    }
}

