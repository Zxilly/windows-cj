@When[Windows_Win32_Media_LibrarySharingServices == "on"]
@C
public struct WindowsMediaLibrarySharingDeviceAuthorizationStatus {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: WindowsMediaLibrarySharingDeviceAuthorizationStatus): Bool {
        return this.value == other.value
    }
    public operator func !=(other: WindowsMediaLibrarySharingDeviceAuthorizationStatus): Bool {
        return this.value != other.value
    }
}

