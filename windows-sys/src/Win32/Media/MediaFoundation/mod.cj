@When[Windows_Win32_Media_MediaFoundation == "on"]
// NOTE: union represented as size-equivalent VArray slot with typed `mut prop` accessors
// (Cangjie paradigm: `@C struct` cannot host a union variant; ABI footprint is preserved)
@C
public struct MFPaletteEntry {
    public var _raw: VArray<UInt8, $4> = VArray<UInt8, $4>(repeat: 0)

    public mut prop argb: MFARGB {
        get() {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<MFARGB>(p)
                return ptr.read()
            }
        }
        set(val) {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<MFARGB>(p)
                ptr.write(val)
                _raw = rawStorage
            }
        }
    }

    public mut prop ayCbCr: MFAYUVSample {
        get() {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<MFAYUVSample>(p)
                return ptr.read()
            }
        }
        set(val) {
            unsafe {
                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<MFAYUVSample>(p)
                ptr.write(val)
                _raw = rawStorage
            }
        }
    }
    public init() {}
}

