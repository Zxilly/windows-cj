@When[Windows_Win32_System_ErrorReporting == "on"]
@C
public struct WER_SUBMIT_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: WER_SUBMIT_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: WER_SUBMIT_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: WER_SUBMIT_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: WER_SUBMIT_FLAGS): WER_SUBMIT_FLAGS {
        return WER_SUBMIT_FLAGS(this.value | other.value)
    }
    public operator func &(other: WER_SUBMIT_FLAGS): WER_SUBMIT_FLAGS {
        return WER_SUBMIT_FLAGS(this.value & other.value)
    }
    public operator func !(): WER_SUBMIT_FLAGS {
        return WER_SUBMIT_FLAGS(!this.value)
    }
}

