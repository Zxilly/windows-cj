    func WscRegisterForChanges(Reserved: CPointer<Unit>, phCallbackRegistration: CPointer<CPointer<Unit>>, lpCallbackAddress: Win32__impl_l0.LPTHREAD_START_ROUTINE, pContext: CPointer<Unit>): Int32
