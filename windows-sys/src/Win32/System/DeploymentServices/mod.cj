@When[Windows_Win32_System_DeploymentServices == "on"]
public let WDS_LOG_LEVEL_WARNING: Int32 = 2i32
@When[Windows_Win32_System_DeploymentServices == "on"]
public let WDS_LOG_LEVEL_INFO: Int32 = 3i32
