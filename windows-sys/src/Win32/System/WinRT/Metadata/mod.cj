    IMetaDataImport.fromAbiTake(raw)
}

@When[Windows_Win32_System_WinRT_Metadata == "on"]
func viewIMetaDataImport(raw: CPointer<Unit>): IMetaDataImport {
    IMetaDataImport(raw)
}

