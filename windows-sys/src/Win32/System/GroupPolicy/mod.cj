@When[Windows_Win32_System_GroupPolicy == "on"]
@C
public struct SETTINGSTATUS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: SETTINGSTATUS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SETTINGSTATUS): Bool {
        return this.value != other.value
    }
}

