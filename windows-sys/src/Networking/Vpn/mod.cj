    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: VpnRoutingPolicyType): Bool {
        return this.value == other.value
    }
    public operator func !=(other: VpnRoutingPolicyType): Bool {
        return this.value != other.value
    }
}

@When[Windows_Networking_Vpn == "on"]
public let SplitRouting: VpnRoutingPolicyType = VpnRoutingPolicyType(0)

@When[Windows_Networking_Vpn == "on"]
public let ForceAllTrafficOverVpn: VpnRoutingPolicyType = VpnRoutingPolicyType(1)
