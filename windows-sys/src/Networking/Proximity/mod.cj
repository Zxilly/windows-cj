public struct PeerDiscoveryTypes {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: PeerDiscoveryTypes): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PeerDiscoveryTypes): Bool {
        return this.value != other.value
    }

    public func contains(other: PeerDiscoveryTypes): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: PeerDiscoveryTypes): PeerDiscoveryTypes {
        return PeerDiscoveryTypes(this.value | other.value)
    }
    public operator func &(other: PeerDiscoveryTypes): PeerDiscoveryTypes {
        return PeerDiscoveryTypes(this.value & other.value)
    }
    public operator func !(): PeerDiscoveryTypes {
        return PeerDiscoveryTypes(!this.value)
    }
}

