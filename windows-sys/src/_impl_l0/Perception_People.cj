    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: JointPoseAccuracy): Bool {
        return this.value == other.value
    }
    public operator func !=(other: JointPoseAccuracy): Bool {
        return this.value != other.value
    }
}

@When[Windows_Perception_People == "on"]
public let JointPoseAccuracy_High: JointPoseAccuracy = JointPoseAccuracy(0)

@When[Windows_Perception_People == "on"]
public let JointPoseAccuracy_Approximate: JointPoseAccuracy = JointPoseAccuracy(1)
