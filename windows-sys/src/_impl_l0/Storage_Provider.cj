@When[Windows_Storage_Provider == "on"]
public struct UIStatus {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: UIStatus): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UIStatus): Bool {
        return this.value != other.value
    }
}

@When[Windows_Storage_Provider == "on"]
public let UIStatus_Unavailable: UIStatus = UIStatus(0)

@When[Windows_Storage_Provider == "on"]
public let UIStatus_Hidden: UIStatus = UIStatus(1)

@When[Windows_Storage_Provider == "on"]
public let UIStatus_Visible: UIStatus = UIStatus(2)

@When[Windows_Storage_Provider == "on"]
public let UIStatus_Complete: UIStatus = UIStatus(3)

