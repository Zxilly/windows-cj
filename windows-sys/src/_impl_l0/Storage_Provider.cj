    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: WriteActivationMode): Bool {
        return this.value == other.value
    }
    public operator func !=(other: WriteActivationMode): Bool {
        return this.value != other.value
