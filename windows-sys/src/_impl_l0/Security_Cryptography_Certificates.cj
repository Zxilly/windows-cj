@When[Windows_Security_Cryptography_Certificates == "on"]
public struct KeySize {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: KeySize): Bool {
        return this.value == other.value
    }
    public operator func !=(other: KeySize): Bool {
        return this.value != other.value
    }
}

