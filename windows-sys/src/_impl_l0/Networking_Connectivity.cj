public struct NetworkTypes {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: NetworkTypes): Bool {
        return this.value == other.value
    }
    public operator func !=(other: NetworkTypes): Bool {
        return this.value != other.value
    }

    public func contains(other: NetworkTypes): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: NetworkTypes): NetworkTypes {
        return NetworkTypes(this.value | other.value)
    }
    public operator func &(other: NetworkTypes): NetworkTypes {
        return NetworkTypes(this.value & other.value)
    }
    public operator func !(): NetworkTypes {
        return NetworkTypes(!this.value)
    }
}

