    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: TargetedContentValueKind): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TargetedContentValueKind): Bool {
        return this.value != other.value
    }
}

@When[Windows_Services_TargetedContent == "on"]
public let TargetedContentValueKind_String: TargetedContentValueKind = TargetedContentValueKind(0)

