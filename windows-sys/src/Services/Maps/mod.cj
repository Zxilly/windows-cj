@When[Windows_Services_Maps == "on"]
@C
public struct MapRouteRestrictions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: MapRouteRestrictions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: MapRouteRestrictions): Bool {
        return this.value != other.value
    }

    public func contains(other: MapRouteRestrictions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: MapRouteRestrictions): MapRouteRestrictions {
        return MapRouteRestrictions(this.value | other.value)
    }
    public operator func &(other: MapRouteRestrictions): MapRouteRestrictions {
        return MapRouteRestrictions(this.value & other.value)
    }
    public operator func !(): MapRouteRestrictions {
        return MapRouteRestrictions(!this.value)
    }
}

@When[Windows_Services_Maps == "on"]
public let None: MapRouteRestrictions = MapRouteRestrictions(0)

@When[Windows_Services_Maps == "on"]
public let Highways: MapRouteRestrictions = MapRouteRestrictions(1)

