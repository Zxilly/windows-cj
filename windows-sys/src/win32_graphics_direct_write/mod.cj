@C
public struct DWRITE_FONT_SIMULATIONS {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: DWRITE_FONT_SIMULATIONS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: DWRITE_FONT_SIMULATIONS): Bool {
        return this.value != other.value
    }

    public func contains(other: DWRITE_FONT_SIMULATIONS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: DWRITE_FONT_SIMULATIONS): DWRITE_FONT_SIMULATIONS {
        return DWRITE_FONT_SIMULATIONS(this.value | other.value)
    }
    public operator func &(other: DWRITE_FONT_SIMULATIONS): DWRITE_FONT_SIMULATIONS {
        return DWRITE_FONT_SIMULATIONS(this.value & other.value)
    }
    public operator func !(): DWRITE_FONT_SIMULATIONS {
        return DWRITE_FONT_SIMULATIONS(!this.value)
    }
}

