    }
    public operator func !=(other: PwmPulsePolarity): Bool {
        return this.value != other.value
    }
}

@When[Windows_Devices_Pwm == "on"]
public let ActiveHigh: PwmPulsePolarity = PwmPulsePolarity(0)

@When[Windows_Devices_Pwm == "on"]
public let ActiveLow: PwmPulsePolarity = PwmPulsePolarity(1)
