        return this.value != other.value
    }
}

@When[Windows_Devices_Geolocation == "on"]
public let VisitStateChange_TrackingLost: VisitStateChange = VisitStateChange(0)

@When[Windows_Devices_Geolocation == "on"]
public let VisitStateChange_Arrived: VisitStateChange = VisitStateChange(1)

@When[Windows_Devices_Geolocation == "on"]
public let VisitStateChange_Departed: VisitStateChange = VisitStateChange(2)

@When[Windows_Devices_Geolocation == "on"]
public let VisitStateChange_OtherMovement: VisitStateChange = VisitStateChange(3)
