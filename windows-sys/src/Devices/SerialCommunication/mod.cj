                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func GetDeviceSelector(): CPointer<UInt16> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetDeviceSelector(liveRaw)
    }

    public unsafe func GetDeviceSelectorFromPortName(portName: CPointer<UInt16>): CPointer<UInt16> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetDeviceSelectorFromPortName(liveRaw, portName)
    }

    public unsafe func GetDeviceSelectorFromUsbVidPid(vendorId: UInt16, productId: UInt16): CPointer<UInt16> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetDeviceSelectorFromUsbVidPid(liveRaw, vendorId, productId)
    }

    public unsafe func FromIdAsync(deviceId: CPointer<UInt16>): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.FromIdAsync(liveRaw, deviceId)
    }
}

