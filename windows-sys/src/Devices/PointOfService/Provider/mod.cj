        let __vt = vtbl()
        let __liveRaw = asRaw()
        __vt.SetIsDecodeLengthSupported(__liveRaw, value)
    }

    public unsafe func CreateAttributes(): CPointer<Unit> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.CreateAttributes(__liveRaw)
    }
}
