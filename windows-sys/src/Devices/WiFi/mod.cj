@When[Windows_Devices_WiFi == "on"]
@C
public struct WiFiReconnectionKind {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: WiFiReconnectionKind): Bool {
        return this.value == other.value
    }
    public operator func !=(other: WiFiReconnectionKind): Bool {
        return this.value != other.value
    }
}

