public struct UsbReadOptions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: UsbReadOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UsbReadOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: UsbReadOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: UsbReadOptions): UsbReadOptions {
        return UsbReadOptions(this.value | other.value)
    }
    public operator func &(other: UsbReadOptions): UsbReadOptions {
        return UsbReadOptions(this.value & other.value)
    }
    public operator func !(): UsbReadOptions {
        return UsbReadOptions(!this.value)
    }
}

