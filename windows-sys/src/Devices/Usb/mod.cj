public let IgnoreShortPacket: UsbReadOptions = UsbReadOptions(4)

@When[Windows_Devices_Usb == "on"]
public let AllowPartialReads: UsbReadOptions = UsbReadOptions(8)

@When[Windows_Devices_Usb == "on"]
@C
public struct UsbTransferDirection {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: UsbTransferDirection): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UsbTransferDirection): Bool {
        return this.value != other.value
    }
}

@When[Windows_Devices_Usb == "on"]
public let Out: UsbTransferDirection = UsbTransferDirection(0)

@When[Windows_Devices_Usb == "on"]
public let In: UsbTransferDirection = UsbTransferDirection(1)

@When[Windows_Devices_Usb == "on"]
@C
public struct UsbWriteOptions {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: UsbWriteOptions): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UsbWriteOptions): Bool {
        return this.value != other.value
    }

    public func contains(other: UsbWriteOptions): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: UsbWriteOptions): UsbWriteOptions {
        return UsbWriteOptions(this.value | other.value)
    }
    public operator func &(other: UsbWriteOptions): UsbWriteOptions {
        return UsbWriteOptions(this.value & other.value)
    }
    public operator func !(): UsbWriteOptions {
        return UsbWriteOptions(!this.value)
    }
}

@When[Windows_Devices_Usb == "on"]
public let None: UsbWriteOptions = UsbWriteOptions(0)

@When[Windows_Devices_Usb == "on"]
public let AutoClearStall: UsbWriteOptions = UsbWriteOptions(1)

@When[Windows_Devices_Usb == "on"]
public let ShortPacketTerminate: UsbWriteOptions = UsbWriteOptions(2)
