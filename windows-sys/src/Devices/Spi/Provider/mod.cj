    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: ProviderSpiMode): Bool {
        return this.value == other.value
    }
    public operator func !=(other: ProviderSpiMode): Bool {
        return this.value != other.value
    }
}

@When[Windows_Devices_Spi_Provider == "on"]
public let Mode0: ProviderSpiMode = ProviderSpiMode(0)

@When[Windows_Devices_Spi_Provider == "on"]
public let Mode1: ProviderSpiMode = ProviderSpiMode(1)

@When[Windows_Devices_Spi_Provider == "on"]
public let Mode2: ProviderSpiMode = ProviderSpiMode(2)

@When[Windows_Devices_Spi_Provider == "on"]
public let Mode3: ProviderSpiMode = ProviderSpiMode(3)

@When[Windows_Devices_Spi_Provider == "on"]
@C
