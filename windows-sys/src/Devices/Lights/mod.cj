@When[Windows_Devices_Lights == "on"]
@C
public struct LampPurposes {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: LampPurposes): Bool {
        return this.value == other.value
    }
    public operator func !=(other: LampPurposes): Bool {
        return this.value != other.value
    }

    public func contains(other: LampPurposes): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: LampPurposes): LampPurposes {
        return LampPurposes(this.value | other.value)
    }
    public operator func &(other: LampPurposes): LampPurposes {
        return LampPurposes(this.value & other.value)
    }
    public operator func !(): LampPurposes {
        return LampPurposes(!this.value)
    }
}

