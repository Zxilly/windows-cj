            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func Create(maxOutstandingFrameCountForWrite: UInt32, format: Graphics_Imaging.BitmapPixelFormat, resolution: Foundation_impl.Size, alpha: Graphics_Imaging.BitmapAlphaMode): CPointer<Unit> {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Create(__liveRaw, maxOutstandingFrameCountForWrite, format, resolution, alpha)
    }
}

@When[Windows_Devices_Perception_Provider == "on"]
public type PerceptionStartFaceAuthenticationHandler = CFunc<(CPointer<Unit>) -> Bool>

@When[Windows_Devices_Perception_Provider == "on"]
public type PerceptionStopFaceAuthenticationHandler = CFunc<(CPointer<Unit>) -> Unit>
