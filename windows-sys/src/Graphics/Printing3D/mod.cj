    public operator func ==(other: Printing3DTextureEdgeBehavior): Bool {
        return this.value == other.value
    }
    public operator func !=(other: Printing3DTextureEdgeBehavior): Bool {
        return this.value != other.value
    }
}

@When[Windows_Graphics_Printing3D == "on"]
public let Printing3DTextureEdgeBehavior_None: Printing3DTextureEdgeBehavior = Printing3DTextureEdgeBehavior(0)

@When[Windows_Graphics_Printing3D == "on"]
public let Printing3DTextureEdgeBehavior_Wrap: Printing3DTextureEdgeBehavior = Printing3DTextureEdgeBehavior(1)

@When[Windows_Graphics_Printing3D == "on"]
public let Printing3DTextureEdgeBehavior_Mirror: Printing3DTextureEdgeBehavior = Printing3DTextureEdgeBehavior(2)

@When[Windows_Graphics_Printing3D == "on"]
public let Printing3DTextureEdgeBehavior_Clamp: Printing3DTextureEdgeBehavior = Printing3DTextureEdgeBehavior(3)
