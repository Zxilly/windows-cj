@When[Windows_Graphics_Printing_OptionDetails == "on"]
@C
public struct PrintOptionStates {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: PrintOptionStates): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PrintOptionStates): Bool {
        return this.value != other.value
    }

    public func contains(other: PrintOptionStates): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: PrintOptionStates): PrintOptionStates {
        return PrintOptionStates(this.value | other.value)
    }
    public operator func &(other: PrintOptionStates): PrintOptionStates {
        return PrintOptionStates(this.value & other.value)
    }
    public operator func !(): PrintOptionStates {
        return PrintOptionStates(!this.value)
    }
}

