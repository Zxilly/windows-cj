@When[Windows_Graphics_Printing == "on"]
@C
public struct PrintOrientation {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: PrintOrientation): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PrintOrientation): Bool {
        return this.value != other.value
    }
}

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_Default: PrintOrientation = PrintOrientation(0)

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_NotAvailable: PrintOrientation = PrintOrientation(1)

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_PrinterCustom: PrintOrientation = PrintOrientation(2)

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_Portrait: PrintOrientation = PrintOrientation(3)

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_PortraitFlipped: PrintOrientation = PrintOrientation(4)

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_Landscape: PrintOrientation = PrintOrientation(5)

@When[Windows_Graphics_Printing == "on"]
public let PrintOrientation_LandscapeFlipped: PrintOrientation = PrintOrientation(6)

