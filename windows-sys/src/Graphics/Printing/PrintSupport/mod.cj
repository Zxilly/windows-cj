    unsafe func vtbl(): IPrintSupportSettingsUISessionVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return IPrintSupportSettingsUISessionVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<IPrintSupportSettingsUISessionVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func SessionPrintTicket(): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.SessionPrintTicket(liveRaw)
    }

    public unsafe func DocumentTitle(): CPointer<UInt16> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.DocumentTitle(liveRaw)
    }

    public unsafe func LaunchKind(): SettingsLaunchKind {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.LaunchKind(liveRaw)
    }

    public unsafe func UpdatePrintTicket(printTicket: CPointer<Unit>): Unit {
        let v = vtbl()
        let liveRaw = asRaw()
        v.UpdatePrintTicket(liveRaw, printTicket)
    }

    public unsafe func SessionInfo(): CPointer<Unit> {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.SessionInfo(liveRaw)
    }
