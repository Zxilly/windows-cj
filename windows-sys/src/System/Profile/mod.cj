    public operator func ==(other: UnsupportedAppRequirementReasons): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UnsupportedAppRequirementReasons): Bool {
        return this.value != other.value
    }

    public func contains(other: UnsupportedAppRequirementReasons): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: UnsupportedAppRequirementReasons): UnsupportedAppRequirementReasons {
        return UnsupportedAppRequirementReasons(this.value | other.value)
    }
    public operator func &(other: UnsupportedAppRequirementReasons): UnsupportedAppRequirementReasons {
        return UnsupportedAppRequirementReasons(this.value & other.value)
    }
    public operator func !(): UnsupportedAppRequirementReasons {
        return UnsupportedAppRequirementReasons(!this.value)
    }
}

@When[Windows_System_Profile == "on"]
public let Unknown: UnsupportedAppRequirementReasons = UnsupportedAppRequirementReasons(0)

@When[Windows_System_Profile == "on"]
public let DeniedBySystem: UnsupportedAppRequirementReasons = UnsupportedAppRequirementReasons(1)
