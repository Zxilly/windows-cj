@When[Windows_System_Update == "on"]
public let Error: SystemUpdateManagerState = SystemUpdateManagerState(11)

@When[Windows_System_Update == "on"]
@C
public struct SystemUpdateStartInstallAction {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: SystemUpdateStartInstallAction): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SystemUpdateStartInstallAction): Bool {
        return this.value != other.value
    }
}

@When[Windows_System_Update == "on"]
public let UpToReboot: SystemUpdateStartInstallAction = SystemUpdateStartInstallAction(0)

@When[Windows_System_Update == "on"]
public let AllowReboot: SystemUpdateStartInstallAction = SystemUpdateStartInstallAction(1)
