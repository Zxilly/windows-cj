    public operator func !=(other: SystemUpdateStartInstallAction): Bool {
        return this.value != other.value
    }
}

@When[Windows_System_Update == "on"]
public let SystemUpdateStartInstallAction_UpToReboot: SystemUpdateStartInstallAction = SystemUpdateStartInstallAction(0)

@When[Windows_System_Update == "on"]
public let SystemUpdateStartInstallAction_AllowReboot: SystemUpdateStartInstallAction = SystemUpdateStartInstallAction(1)
