@When[Windows_Security_DataProtection == "on"]
@C
public struct UserDataBufferUnprotectStatus {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: UserDataBufferUnprotectStatus): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UserDataBufferUnprotectStatus): Bool {
        return this.value != other.value
    }
}

@When[Windows_Security_DataProtection == "on"]
public let Succeeded: UserDataBufferUnprotectStatus = UserDataBufferUnprotectStatus(0)

@When[Windows_Security_DataProtection == "on"]
public let Unavailable: UserDataBufferUnprotectStatus = UserDataBufferUnprotectStatus(1)

