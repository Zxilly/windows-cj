@When[Windows_Media_Core == "on"]
@C
public struct TimedTextRubyPosition {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: TimedTextRubyPosition): Bool {
        return this.value == other.value
    }
    public operator func !=(other: TimedTextRubyPosition): Bool {
        return this.value != other.value
    }
}

