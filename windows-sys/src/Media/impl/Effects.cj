@When[Windows_Media_Effects == "on"]
@C
public struct MediaEffectClosedReason {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: MediaEffectClosedReason): Bool {
        return this.value == other.value
    }
    public operator func !=(other: MediaEffectClosedReason): Bool {
        return this.value != other.value
    }
}

