        return this.value == other.value
    }
    public operator func !=(other: TimedMetadataTrackPresentationMode): Bool {
        return this.value != other.value
    }
}

@When[Windows_Media_Playback == "on"]
public let Disabled: TimedMetadataTrackPresentationMode = TimedMetadataTrackPresentationMode(0)

@When[Windows_Media_Playback == "on"]
public let Hidden: TimedMetadataTrackPresentationMode = TimedMetadataTrackPresentationMode(1)

@When[Windows_Media_Playback == "on"]
public let ApplicationPresented: TimedMetadataTrackPresentationMode = TimedMetadataTrackPresentationMode(2)

@When[Windows_Media_Playback == "on"]
public let PlatformPresented: TimedMetadataTrackPresentationMode = TimedMetadataTrackPresentationMode(3)
