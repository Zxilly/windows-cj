@When[Windows_Media_Playback == "on"]
public let MediaPlayerState_Playing: MediaPlayerState = MediaPlayerState(3)

@When[Windows_Media_Playback == "on"]
public let MediaPlayerState_Paused: MediaPlayerState = MediaPlayerState(4)

@When[Windows_Media_Playback == "on"]
public let MediaPlayerState_Stopped: MediaPlayerState = MediaPlayerState(5)

@When[Windows_Media_Playback == "on"]
@C
public struct SphericalVideoProjectionMode {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: SphericalVideoProjectionMode): Bool {
        return this.value == other.value
    }
    public operator func !=(other: SphericalVideoProjectionMode): Bool {
        return this.value != other.value
    }
}

@When[Windows_Media_Playback == "on"]
public let SphericalVideoProjectionMode_Spherical: SphericalVideoProjectionMode = SphericalVideoProjectionMode(0)

@When[Windows_Media_Playback == "on"]
public let SphericalVideoProjectionMode_Flat: SphericalVideoProjectionMode = SphericalVideoProjectionMode(1)

