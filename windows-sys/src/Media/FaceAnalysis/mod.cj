        return v.IsBitmapPixelFormatSupported(liveRaw, bitmapPixelFormat)
    }

    public unsafe func IsSupported(): Bool {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.IsSupported(liveRaw)
    }
}
