    public init(raw: CPointer<Unit>) {
        super(raw)
    }

    protected init(raw: CPointer<Unit>, takeOwnership!: Bool, allowManualRelease!: Bool) {
        super(raw, takeOwnership: takeOwnership, allowManualRelease: allowManualRelease)
    }

    public static func fromAbiTake(raw: CPointer<Unit>): ISpeechSynthesizer {
        ISpeechSynthesizer(raw, takeOwnership: true, allowManualRelease: false)
    }

    public static func viewOf(raw: CPointer<Unit>): ISpeechSynthesizer {
        ISpeechSynthesizer(raw, takeOwnership: false, allowManualRelease: false)
    }

    public static func iid(): GUID {
        return GUID(0xCE9F7C76, 0x97F4, 0x4CED, 0xAD, 0x68, 0xD5, 0x1C, 0x45, 0x8E, 0x45, 0xC6)
    }

    public static func descriptor(): InterfaceDescriptor<ISpeechSynthesizer> {
        return InterfaceDescriptor<ISpeechSynthesizer>("ISpeechSynthesizer", ISpeechSynthesizer.iid(), takeISpeechSynthesizerFromAbi, viewISpeechSynthesizer)
    }

    public unsafe func vtbl(): ISpeechSynthesizerVtbl {
        readVtbl<ISpeechSynthesizerVtbl>(ISpeechSynthesizerVtbl())
    }

    public unsafe func SynthesizeTextToStreamAsync(text: CPointer<Unit>, result__: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.SynthesizeTextToStreamAsync(__liveRaw, text, result__)
    }

    public unsafe func SynthesizeSsmlToStreamAsync(Ssml: CPointer<Unit>, result__: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.SynthesizeSsmlToStreamAsync(__liveRaw, Ssml, result__)
    }

    public unsafe func SetVoice(value: CPointer<Unit>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.SetVoice(__liveRaw, value)
    }

    public unsafe func Voice(result__: CPointer<CPointer<Unit>>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.Voice(__liveRaw, result__)
    }
}

@When[Windows_Media_SpeechSynthesis == "on"]
@C
public struct ISpeechSynthesizer2Vtbl {
    public var base_: windows_interface.IInspectableVtbl = windows_interface.IInspectableVtbl()
    public var Options: CFunc<(CPointer<Unit>, CPointer<CPointer<Unit>>) -> Int32> = { _, _ => 0 }
    public init() {}
}

@When[Windows_Media_SpeechSynthesis == "on"]
func takeISpeechSynthesizer2FromAbi(raw: CPointer<Unit>): ISpeechSynthesizer2 {
    ISpeechSynthesizer2.fromAbiTake(raw)
}

@When[Windows_Media_SpeechSynthesis == "on"]
func viewISpeechSynthesizer2(raw: CPointer<Unit>): ISpeechSynthesizer2 {
    ISpeechSynthesizer2.viewOf(raw)
}

