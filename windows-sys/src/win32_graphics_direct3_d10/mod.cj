@When[feat_windows_win32_graphics_direct3_d10 == "on"]
func wrapID3D10DeviceOwned(raw: CPointer<Unit>): ID3D10Device {
    ID3D10Device(raw, ownsReference: true)
}

@When[feat_windows_win32_graphics_direct3_d10 == "on"]
func wrapID3D10DeviceBorrowed(raw: CPointer<Unit>): ID3D10Device {
    ID3D10Device(raw)
}

@When[feat_windows_win32_graphics_direct3_d10 == "on"]
public class ID3D10Device <: ComInterface & Resource {
    private let raw_: CPointer<Unit>
    private let ownsReference_: Bool
    private var closed_: Bool = false

    public init(raw: CPointer<Unit>, ownsReference!: Bool = false) {
        this.raw_ = raw
        this.ownsReference_ = ownsReference
    }

    public static func fromRaw(raw: CPointer<Unit>): ID3D10Device {
        ID3D10Device(raw, ownsReference: true)
    }

    public static func fromRawBorrowed(raw: CPointer<Unit>): ID3D10Device {
        ID3D10Device(raw)
    }

    public static func iid(): GUID {
        return GUID(0x9B7E4C0F, 0x342C, 0x4106, 0xA1, 0x9F, 0x4F, 0x27, 0x04, 0xF6, 0x89, 0xF0)
    }

    public static func descriptor(): InterfaceDescriptor<ID3D10Device> {
        return InterfaceDescriptor<ID3D10Device>("ID3D10Device", ID3D10Device.iid(), wrapID3D10DeviceOwned, wrapID3D10DeviceBorrowed)
    }

    public func asRaw(): CPointer<Unit> {
        if (closed_) {
            return CPointer<Unit>()
        }
        raw_
    }

    public func isOwned(): Bool { ownsReference_ }

    public func isClosed(): Bool { closed_ }

    unsafe func vtbl(): ID3D10DeviceVtbl {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return ID3D10DeviceVtbl()
        }
        let vtblPtrPtr = CPointer<CPointer<ID3D10DeviceVtbl>>(liveRaw)
        let vtblPtr = vtblPtrPtr.read()
        return vtblPtr.read()
    }

    public func addRef(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            return baseVtbl.AddRef(liveRaw)
        }
    }

    public func release(): UInt32 {
        let liveRaw = asRaw()
        if (liveRaw.isNull()) {
            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsReference_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

