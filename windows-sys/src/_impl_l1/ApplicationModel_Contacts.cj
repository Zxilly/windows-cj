        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.GetForUser(__liveRaw, user, result__)
    }

    public unsafe func IsSupported(result__: CPointer<Bool>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.IsSupported(__liveRaw, result__)
    }
}
