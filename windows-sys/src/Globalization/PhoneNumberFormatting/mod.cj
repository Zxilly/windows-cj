@When[Windows_Globalization_PhoneNumberFormatting == "on"]
public let PhoneNumberFormat_Rfc3966: PhoneNumberFormat = PhoneNumberFormat(3)

@When[Windows_Globalization_PhoneNumberFormatting == "on"]
@C
public struct PhoneNumberMatchResult {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: PhoneNumberMatchResult): Bool {
        return this.value == other.value
    }
    public operator func !=(other: PhoneNumberMatchResult): Bool {
        return this.value != other.value
    }
}

@When[Windows_Globalization_PhoneNumberFormatting == "on"]
public let PhoneNumberMatchResult_NoMatch: PhoneNumberMatchResult = PhoneNumberMatchResult(0)

@When[Windows_Globalization_PhoneNumberFormatting == "on"]
public let PhoneNumberMatchResult_ShortNationalSignificantNumberMatch: PhoneNumberMatchResult = PhoneNumberMatchResult(1)

@When[Windows_Globalization_PhoneNumberFormatting == "on"]
public let PhoneNumberMatchResult_NationalSignificantNumberMatch: PhoneNumberMatchResult = PhoneNumberMatchResult(2)

@When[Windows_Globalization_PhoneNumberFormatting == "on"]
public let PhoneNumberMatchResult_ExactMatch: PhoneNumberMatchResult = PhoneNumberMatchResult(3)

