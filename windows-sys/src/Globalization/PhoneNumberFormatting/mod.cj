            return 0u32
        }
        unsafe {
            let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
            let baseVtbl = baseVtblPtr.read()
            let count = baseVtbl.Release(liveRaw)
            closed_ = true
            return count
        }
    }

    public unsafe func query<T>(descriptor: InterfaceDescriptor<T>): Option<T> {
        queryInterfaceAs(asRaw(), descriptor)
    }

    public func close(): Unit {
        let liveRaw = asRaw()
        if (!liveRaw.isNull() && ownsHandle_) {
            unsafe {
                let baseVtblPtr = CPointer<CPointer<IUnknownVtbl>>(liveRaw).read()
                let baseVtbl = baseVtblPtr.read()
                baseVtbl.Release(liveRaw)
            }
        }
        closed_ = true
    }

    public unsafe func TryParse(input: CPointer<UInt16>, phoneNumber: CPointer<CPointer<Unit>>): PhoneNumberParseResult {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.TryParse(liveRaw, input, phoneNumber)
    }

    public unsafe func TryParseWithRegion(input: CPointer<UInt16>, regionCode: CPointer<UInt16>, phoneNumber: CPointer<CPointer<Unit>>): PhoneNumberParseResult {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.TryParseWithRegion(liveRaw, input, regionCode, phoneNumber)
    }
}

