// Math helpers stay in companion types rather than bolting operator-heavy APIs
// onto the WinRT numerics structs themselves.
public struct Vector2Math {
    public static func new(x: Float32, y: Float32): Vector2 { return vector2(x, y) }
    public static func zero(): Vector2 { return vector2(0.0, 0.0) }
    public static func one(): Vector2 { return vector2(1.0, 1.0) }
    public static func unitX(): Vector2 { return vector2(1.0, 0.0) }
    public static func unitY(): Vector2 { return vector2(0.0, 1.0) }
    public static func neg(value: Vector2): Vector2 { return vector2(-value.X, -value.Y) }
    public static func add(left: Vector2, right: Vector2): Vector2 { return vector2(left.X + right.X, left.Y + right.Y) }
    public static func sub(left: Vector2, right: Vector2): Vector2 { return vector2(left.X - right.X, left.Y - right.Y) }
    public static func mul(left: Vector2, right: Vector2): Vector2 { return vector2(left.X * right.X, left.Y * right.Y) }
    public static func mulScalar(value: Vector2, scale: Float32): Vector2 { return vector2(value.X * scale, value.Y * scale) }
    public static func div(left: Vector2, right: Vector2): Vector2 { return vector2(left.X / right.X, left.Y / right.Y) }
    public static func divScalar(value: Vector2, scale: Float32): Vector2 { return vector2(value.X / scale, value.Y / scale) }
    public static func dot(left: Vector2, right: Vector2): Float32 { return left.X * right.X + left.Y * right.Y }
    public static func lengthSquared(value: Vector2): Float32 { return Vector2Math.dot(value, value) }
    public static func length(value: Vector2): Float32 { return sqrt(Vector2Math.lengthSquared(value)) }
    public static func distanceSquared(left: Vector2, right: Vector2): Float32 { return Vector2Math.lengthSquared(Vector2Math.sub(left, right)) }
    public static func distance(left: Vector2, right: Vector2): Float32 { return sqrt(Vector2Math.distanceSquared(left, right)) }
    public static func normalize(value: Vector2): Vector2 { let len = Vector2Math.length(value); return Vector2Math.divScalar(value, len) }
}

public struct Vector3Math {
    public static func new(x: Float32, y: Float32, z: Float32): Vector3 { return vector3(x, y, z) }
    public static func zero(): Vector3 { return vector3(0.0, 0.0, 0.0) }
    public static func one(): Vector3 { return vector3(1.0, 1.0, 1.0) }
    public static func unitX(): Vector3 { return vector3(1.0, 0.0, 0.0) }
    public static func unitY(): Vector3 { return vector3(0.0, 1.0, 0.0) }
    public static func unitZ(): Vector3 { return vector3(0.0, 0.0, 1.0) }
    public static func neg(value: Vector3): Vector3 { return vector3(-value.X, -value.Y, -value.Z) }
    public static func add(left: Vector3, right: Vector3): Vector3 { return vector3(left.X + right.X, left.Y + right.Y, left.Z + right.Z) }
    public static func sub(left: Vector3, right: Vector3): Vector3 { return vector3(left.X - right.X, left.Y - right.Y, left.Z - right.Z) }
    public static func mul(left: Vector3, right: Vector3): Vector3 { return vector3(left.X * right.X, left.Y * right.Y, left.Z * right.Z) }
    public static func mulScalar(value: Vector3, scale: Float32): Vector3 { return vector3(value.X * scale, value.Y * scale, value.Z * scale) }
    public static func div(left: Vector3, right: Vector3): Vector3 { return vector3(left.X / right.X, left.Y / right.Y, left.Z / right.Z) }
    public static func divScalar(value: Vector3, scale: Float32): Vector3 { return vector3(value.X / scale, value.Y / scale, value.Z / scale) }
    public static func dot(left: Vector3, right: Vector3): Float32 { return left.X * right.X + left.Y * right.Y + left.Z * right.Z }
    public static func lengthSquared(value: Vector3): Float32 { return Vector3Math.dot(value, value) }
    public static func length(value: Vector3): Float32 { return sqrt(Vector3Math.lengthSquared(value)) }
    public static func distanceSquared(left: Vector3, right: Vector3): Float32 { return Vector3Math.lengthSquared(Vector3Math.sub(left, right)) }
    public static func distance(left: Vector3, right: Vector3): Float32 { return sqrt(Vector3Math.distanceSquared(left, right)) }
    public static func normalize(value: Vector3): Vector3 { let len = Vector3Math.length(value); return Vector3Math.divScalar(value, len) }
    public static func cross(left: Vector3, right: Vector3): Vector3 { return vector3(left.Y * right.Z - left.Z * right.Y, left.Z * right.X - left.X * right.Z, left.X * right.Y - left.Y * right.X) }
