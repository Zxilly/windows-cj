        var result__ = CPointer<Unit>()
        let hr = v.Current(asRaw(), CPointer<CPointer<Unit>>(inout result__))
        HRESULT(hr).ok()
        return DialReceiverApp.fromAbiTake(result__)
    }
}

@When[Windows_Media_DialProtocol == "on"]
