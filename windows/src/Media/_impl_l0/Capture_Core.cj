    public static func fromAbiTakeWinrtHandle(raw: CPointer<Unit>): VariablePhotoSequenceCapture {
        if (raw.isNull()) {
            throw windows_core.WindowsException(windows_core.E_POINTER)
        }
        VariablePhotoSequenceCapture.fromAbiTake(raw)
    }

    public static func viewWinrtHandle(raw: CPointer<Unit>): VariablePhotoSequenceCapture {
        VariablePhotoSequenceCapture.viewOf(raw)
    }
}
