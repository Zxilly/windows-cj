        return asIXmlNode().PreviousSibling()
    }

    public unsafe func NextSibling(): IXmlNode {
        return asIXmlNode().NextSibling()
    }

    public unsafe func Attributes(): XmlNamedNodeMap {
        return asIXmlNode().Attributes()
    }

    public unsafe func HasChildNodes(): Bool {
        return asIXmlNode().HasChildNodes()
    }

    public unsafe func OwnerDocument(): XmlDocument {
        return asIXmlNode().OwnerDocument()
    }

    public unsafe func InsertBefore(newChild: IXmlNode, referenceChild: IXmlNode): IXmlNode {
        return asIXmlNode().InsertBefore(newChild, referenceChild)
    }

    public unsafe func ReplaceChild(newChild: IXmlNode, referenceChild: IXmlNode): IXmlNode {
        return asIXmlNode().ReplaceChild(newChild, referenceChild)
    }

    public unsafe func RemoveChild(childNode: IXmlNode): IXmlNode {
        return asIXmlNode().RemoveChild(childNode)
    }

    public unsafe func AppendChild(newChild: IXmlNode): IXmlNode {
        return asIXmlNode().AppendChild(newChild)
    }

    public unsafe func CloneNode(deep: Bool): IXmlNode {
        return asIXmlNode().CloneNode(deep)
    }

    public unsafe func NamespaceUri(): IInspectable {
        return asIXmlNode().NamespaceUri()
    }

    public unsafe func LocalName(): IInspectable {
        return asIXmlNode().LocalName()
    }

    public unsafe func Prefix(): IInspectable {
        return asIXmlNode().Prefix()
    }

    public unsafe func Normalize(): Unit {
        asIXmlNode().Normalize()
    }

    public unsafe func SetPrefix(value: IInspectable): Unit {
        asIXmlNode().SetPrefix(value)
    }

    public unsafe func SelectSingleNode(xpath: windows_core.HString): IXmlNode {
        return asIXmlNodeSelector().SelectSingleNode(xpath)
    }

    public unsafe func SelectNodes(xpath: windows_core.HString): XmlNodeList {
        return asIXmlNodeSelector().SelectNodes(xpath)
    }

    public unsafe func SelectSingleNodeNS(xpath: windows_core.HString, namespaces: IInspectable): IXmlNode {
        return asIXmlNodeSelector().SelectSingleNodeNS(xpath, namespaces)
    }

    public unsafe func SelectNodesNS(xpath: windows_core.HString, namespaces: IInspectable): XmlNodeList {
        return asIXmlNodeSelector().SelectNodesNS(xpath, namespaces)
