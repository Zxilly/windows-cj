}

@When[Windows_Data_Xml_Dom == "on"]
extend XmlText <: windows_core.HandleWinrtType<XmlText> {
    public static func intoWinrtHandle(value: XmlText): CPointer<Unit> {
        value.asRaw()
    }

    public static func fromAbiTakeWinrtHandle(raw: CPointer<Unit>): XmlText {
        if (raw.isNull()) {
            throw windows_core.WindowsException(windows_core.E_POINTER)
        }
        XmlText.fromAbiTake(raw)
    }

    public static func viewWinrtHandle(raw: CPointer<Unit>): XmlText {
        XmlText.viewOf(raw)
    }
}
