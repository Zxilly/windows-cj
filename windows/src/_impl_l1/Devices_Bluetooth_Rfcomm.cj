            throw windows_core.WindowsException(windows_core.E_POINTER)
        }
        RfcommDeviceServicesResult.fromAbiTake(raw)
    }

    public static func viewWinrtHandle(raw: CPointer<Unit>): RfcommDeviceServicesResult {
        RfcommDeviceServicesResult.viewOf(raw)
    }
}
