    public unsafe func IsCanceled(): Bool {
        let v = vtbl()
        var result__ = false
        let hr = v.IsCanceled(asRaw(), CPointer<Bool>(inout result__))
        HRESULT(hr).ok()
        return result__
    }

    public unsafe func GetDeferral(): Foundation.Deferral {
        let v = vtbl()
        var result__ = CPointer<Unit>()
        let hr = v.GetDeferral(asRaw(), CPointer<CPointer<Unit>>(inout result__))
        HRESULT(hr).ok()
        return Foundation.Deferral.fromAbiTake(result__)
    }
}

@When[Windows_UI_Text_Core == "on"]
extend ICoreTextTextRequest <: windows_core.Interface<ICoreTextTextRequest> {}
