package windows

// =============================================================================
// WinRT Property Mapping Patterns
// =============================================================================
// This file demonstrates the pattern for mapping WinRT get_/put_ property
// pairs to Cangjie's prop / mut prop syntax. In production, these would be
// generated by cj-windows-bindgen from .winmd metadata.
//
// Pattern:
//   WinRT:  HRESULT get_PropertyName([out] T* value)
//           HRESULT put_PropertyName(T value)
//   Cangjie:
//     public mut prop propertyName: T {
//         get() { ... vtable call to get_PropertyName ... }
//         set(value) { ... vtable call to put_PropertyName ... }
//     }
//
// Read-only properties use `prop` (no `mut`), only defining `get()`.
//
// Example: hypothetical WinRT FileOpenPicker projection
//
//   public class FileOpenPicker <: Resource {
//       private var raw: CPointer<Unit>
//       private var closed: Bool = false
//
//       // Read-only property: get_FileTypeFilter
//       public prop fileTypeFilter: CPointer<Unit> {
//           get() {
//               var result = CPointer<Unit>()
//               let vtblPtr = unsafe { CPointer<CPointer<CPointer<Unit>>>(raw).read() }
//               let getFn = unsafe {
//                   CFunc<(CPointer<Unit>, CPointer<CPointer<Unit>>) -> Int32>(
//                       (vtblPtr + FILE_TYPE_FILTER_SLOT).read()
//                   )
//               }
//               let hr = unsafe { getFn(raw, CPointer<CPointer<Unit>>(inout result)) }
//               HRESULT(hr).ok()
//               result
//           }
//       }
//
//       // Read-write property: get_/put_SuggestedStartLocation
//       public mut prop suggestedStartLocation: Int32 {
//           get() {
//               var result: Int32 = 0
//               let vtblPtr = unsafe { CPointer<CPointer<CPointer<Unit>>>(raw).read() }
//               let getFn = unsafe {
//                   CFunc<(CPointer<Unit>, CPointer<Int32>) -> Int32>(
//                       (vtblPtr + GET_SUGGESTED_START_LOCATION_SLOT).read()
//                   )
//               }
//               let hr = unsafe { getFn(raw, CPointer<Int32>(inout result)) }
//               HRESULT(hr).ok()
//               result
//           }
//           set(value) {
//               let vtblPtr = unsafe { CPointer<CPointer<CPointer<Unit>>>(raw).read() }
//               let putFn = unsafe {
//                   CFunc<(CPointer<Unit>, Int32) -> Int32>(
//                       (vtblPtr + PUT_SUGGESTED_START_LOCATION_SLOT).read()
//                   )
//               }
//               let hr = unsafe { putFn(raw, value) }
//               HRESULT(hr).ok()
//           }
//       }
//
//       public func isClosed(): Bool { closed }
//       public func close(): Unit {
//           if (!closed && !raw.isNull()) {
//               // Release via IUnknown
//               unsafe {
//                   let vtblPtr = CPointer<CPointer<IUnknownVtbl>>(raw).read()
//                   vtblPtr.read().Release(raw)
//               }
//               closed = true
//           }
//       }
//   }

// =============================================================================
// VtableHelper — utility for reading vtable function pointers by slot index
// =============================================================================
// This helper simplifies the pattern of reading a function pointer from a
// COM vtable at a given slot offset.

public unsafe func vtableSlot(obj: CPointer<Unit>, slot: Int64): CPointer<Unit> {
    let vtblPtr = CPointer<CPointer<CPointer<Unit>>>(obj).read()
    (vtblPtr + slot).read()
}

// callVtableMethod0 — call a vtable method with 0 out-params, return HRESULT
public unsafe func callVtableMethod0(obj: CPointer<Unit>, slot: Int64): Int32 {
    let fn = CFunc<(CPointer<Unit>) -> Int32>(vtableSlot(obj, slot))
    fn(obj)
}

// callVtableGet — call a vtable getter that writes one output value via pointer
// Returns the HRESULT. Caller reads the value from the inout parameter.
public unsafe func callVtableGetInt32(
    obj: CPointer<Unit>,
    slot: Int64,
    result: CPointer<Int32>
): Int32 {
    let fn = CFunc<(CPointer<Unit>, CPointer<Int32>) -> Int32>(vtableSlot(obj, slot))
    fn(obj, result)
}

public unsafe func callVtableGetPtr(
    obj: CPointer<Unit>,
    slot: Int64,
    result: CPointer<CPointer<Unit>>
): Int32 {
    let fn = CFunc<(CPointer<Unit>, CPointer<CPointer<Unit>>) -> Int32>(vtableSlot(obj, slot))
    fn(obj, result)
}

// callVtablePutInt32 — call a vtable setter that takes one Int32 value
public unsafe func callVtablePutInt32(
    obj: CPointer<Unit>,
    slot: Int64,
    value: Int32
): Int32 {
    let fn = CFunc<(CPointer<Unit>, Int32) -> Int32>(vtableSlot(obj, slot))
    fn(obj, value)
}

public unsafe func callVtablePutPtr(
    obj: CPointer<Unit>,
    slot: Int64,
    value: CPointer<Unit>
): Int32 {
    let fn = CFunc<(CPointer<Unit>, CPointer<Unit>) -> Int32>(vtableSlot(obj, slot))
    fn(obj, value)
}

func int32BitsToUInt32(value: Int32): UInt32 {
    if (value >= 0) {
        return UInt32(value)
    }
    UInt32(4294967296i64 + Int64(value))
}

// =============================================================================
// Example WinRT Property Wrapper: CreateStructView
// =============================================================================
// This demonstrates a real WinRT property wrapping class that maps get_/put_
// properties to Cangjie mut prop syntax. A CREATESTRUCTW contains window
// creation parameters, and this view provides typed access to them.

public class CreateStructView {
    private var raw: CPointer<CREATESTRUCTW>
    private var closed: Bool = false

    public init(raw: CPointer<CREATESTRUCTW>) {
        this.raw = raw
    }

    // Read-only property: lpCreateParams context value
    public prop lpCreateParams: CPointer<Unit> {
        get() {
            unsafe { raw.read().lpCreateParams }
        }
    }

    // Read-only property: window style
    public prop style: UInt32 {
        get() {
            int32BitsToUInt32(unsafe { raw.read().style })
        }
    }

    // Read-only property: instance handle
    public prop hInstance: HINSTANCE {
        get() {
            unsafe { raw.read().hInstance }
        }
    }

    public func isClosed(): Bool { closed }

    public func close(): Unit {
        closed = true
        // Note: this is only a call-scoped raw view; the caller still manages lifetime.
    }
}
