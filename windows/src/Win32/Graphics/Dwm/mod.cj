@When[DWMAPI == "on"]
foreign {
    func DwmAttachMilContent(hwnd: CPointer<Unit>): Int32
    func DwmDefWindowProc(hWnd: CPointer<Unit>, msg: UInt32, wParam: UIntNative, lParam: IntNative, plResult: CPointer<IntNative>): Int32
