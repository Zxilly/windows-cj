    public operator func |(other: CONSOLE_MODE): CONSOLE_MODE {
        return CONSOLE_MODE(this.value | other.value)
    }
    public operator func &(other: CONSOLE_MODE): CONSOLE_MODE {
        return CONSOLE_MODE(this.value & other.value)
