                var rawStorage = _raw
                let base = CPointer<UInt8>(inout rawStorage)
                let p = base
                let ptr = CPointer<SUB_Q_TRACK_ISRCAbi>(p)
                ptr.write(SUB_Q_TRACK_ISRC.projectAbi(val))
                _raw = rawStorage
            }
        }
    }
    public init() {}
}
