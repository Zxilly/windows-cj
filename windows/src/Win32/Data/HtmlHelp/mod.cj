        return __vt.GetRowStatus(__liveRaw, lRowFirst, cRows, lpRowStatus)
    }

    public unsafe func GetColumnStatus(lpColStatus: CPointer<COLUMNSTATUSAbi>): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.GetColumnStatus(__liveRaw, lpColStatus)
    }
}
