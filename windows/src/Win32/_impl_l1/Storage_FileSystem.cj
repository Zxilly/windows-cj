    public static func winrtOutputBridge(): windows_core.WinrtOutputBridge<WIN32_STREAM_ID> {
        windows_core.ProjectedCopyWinrtOutputBridge<WIN32_STREAM_ID, WIN32_STREAM_IDAbi, WIN32_STREAM_ID>()
    }
}
