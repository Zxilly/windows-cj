    }

    public unsafe func DestinationReachableNoQOCInfo(bstrDestination: CPointer<UInt16>, bstrConnection: CPointer<UInt16>, ulType: UInt32): Int32 {
        let __vt = vtbl()
        let __liveRaw = asRaw()
        return __vt.DestinationReachableNoQOCInfo(__liveRaw, bstrDestination, bstrConnection, ulType)
    }
}
