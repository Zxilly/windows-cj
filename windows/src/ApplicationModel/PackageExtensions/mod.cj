    public unsafe func RemovePackageUninstalling(token: windows_collections.EventRegistrationToken): Unit {
        defaultInterface().RemovePackageUninstalling(token)
    }

    public unsafe func PackageStatusChanged(handler: Foundation.TypedEventHandler<PackageExtensionCatalog, PackageExtensionPackageStatusChangedEventArgs>): windows_collections.EventRegistrationToken {
        return defaultInterface().PackageStatusChanged(handler)
    }

    public unsafe func RemovePackageStatusChanged(token: windows_collections.EventRegistrationToken): Unit {
        defaultInterface().RemovePackageStatusChanged(token)
    }

    public static unsafe func Open(packageExtensionName: windows_core.HString): PackageExtensionCatalog {
        var result__: Option<PackageExtensionCatalog> = Option<PackageExtensionCatalog>.None
        try (factory__ = windows_core.factory<PackageExtensionCatalog, IPackageExtensionCatalogStatics>().unwrap()) {
            result__ = Some(factory__.Open(packageExtensionName))
        }
        match (result__) {
            case Some(value) => return value
            case None => throw IllegalStateException("Activation factory call `Open` did not return a value")
        }
    }
}

@When[Windows_ApplicationModel_PackageExtensions == "on"]
extend PackageExtensionCatalog <: windows_core.HandleWinrtType<PackageExtensionCatalog> {
    public static func intoWinrtHandle(value: PackageExtensionCatalog): CPointer<Unit> {
        value.asRaw()
    }

    public static func fromAbiTakeWinrtHandle(raw: CPointer<Unit>): PackageExtensionCatalog {
        if (raw.isNull()) {
            throw windows_core.WindowsException(windows_core.E_POINTER)
        }
        PackageExtensionCatalog.fromAbiTake(raw)
    }

    public static func viewWinrtHandle(raw: CPointer<Unit>): PackageExtensionCatalog {
