@When[Windows_Globalization_PhoneNumberFormatting == "on"]
extend PhoneNumberInfo <: windows_core.HandleWinrtType<PhoneNumberInfo> {
    public static func intoWinrtHandle(value: PhoneNumberInfo): CPointer<Unit> {
        value.asRaw()
    }

    public static func fromAbiTakeWinrtHandle(raw: CPointer<Unit>): PhoneNumberInfo {
        if (raw.isNull()) {
            throw windows_core.WindowsException(windows_core.E_POINTER)
