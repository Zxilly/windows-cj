        let hr = v.GetControllers(asRaw(), CPointer<CPointer<Unit>>(inout result__))
        HRESULT(hr).ok()
        return windows_collections.IVectorView<IAdcControllerProvider>.fromAbiTake(result__)
    }
}

@When[Windows_Devices_Adc_Provider == "on"]
extend IAdcProvider <: windows_core.Interface<IAdcProvider> {}
