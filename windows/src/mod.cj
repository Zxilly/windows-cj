package windows

// Aggregate re-exports for the high-level windows package.
// Users: `import windows.*` to get the full API surface.

// Re-export windows_core (runtime: GUID, HRESULT, ComPtr, CWideString, etc.)
// This takes priority — windows_core provides typed HRESULT constants,
// exception hierarchy, and COM infrastructure.
public import windows_core.*

// Selective re-exports from windows_sys (raw FFI bindings).
// We avoid `public import windows_sys.*` because windows_sys defines raw
// Int32 HRESULT constants (S_OK, E_FAIL, etc.) that conflict with the
// typed HRESULT struct constants from windows_core.

// Handle types
public import windows_sys.{HANDLE, HWND, HINSTANCE, HMODULE, HICON, HCURSOR,
    HBRUSH, HMENU, HDC, HGDIOBJ}

// Basic types and constants
public import windows_sys.{BOOL, LRESULT, WPARAM, LPARAM, ATOM,
    TRUE, FALSE, MAX_PATH, NULL_HANDLE, isInvalidHandle}

// Foundation structs and Win32 error codes
public import windows_sys.{POINT, RECT, SIZE, FILETIME, SECURITY_ATTRIBUTES,
    ERROR_SUCCESS, ERROR_FILE_NOT_FOUND, ERROR_PATH_NOT_FOUND,
    ERROR_ACCESS_DENIED, ERROR_INVALID_HANDLE, ERROR_NOT_ENOUGH_MEMORY,
    ERROR_INVALID_DATA, ERROR_OUTOFMEMORY, ERROR_INVALID_PARAMETER,
    ERROR_INSUFFICIENT_BUFFER, ERROR_ALREADY_EXISTS, ERROR_MORE_DATA,
    ERROR_NO_MORE_FILES, ERROR_IO_PENDING}

// Kernel32 structs and functions
public import windows_sys.{OVERLAPPED, CRITICAL_SECTION, WIN32_FIND_DATAW,
    STARTUPINFOW, PROCESS_INFORMATION}

// User32 structs, functions, and constants
public import windows_sys.{WNDCLASSEXW, MSG, CREATESTRUCTW}

// Window styles
public import windows_sys.{WS_OVERLAPPED, WS_POPUP, WS_CHILD, WS_MINIMIZE,
    WS_VISIBLE, WS_DISABLED, WS_CLIPSIBLINGS, WS_CLIPCHILDREN,
    WS_MAXIMIZE, WS_CAPTION, WS_BORDER, WS_DLGFRAME,
    WS_VSCROLL, WS_HSCROLL, WS_SYSMENU, WS_THICKFRAME,
    WS_MINIMIZEBOX, WS_MAXIMIZEBOX, WS_OVERLAPPEDWINDOW, WS_POPUPWINDOW}

// Extended window styles
public import windows_sys.{WS_EX_DLGMODALFRAME, WS_EX_TOPMOST,
    WS_EX_ACCEPTFILES, WS_EX_TRANSPARENT, WS_EX_APPWINDOW,
    WS_EX_OVERLAPPEDWINDOW, WS_EX_CLIENTEDGE, WS_EX_WINDOWEDGE}

// Window messages
public import windows_sys.{WM_NULL, WM_CREATE, WM_DESTROY, WM_MOVE, WM_SIZE,
    WM_ACTIVATE, WM_SETFOCUS, WM_KILLFOCUS, WM_ENABLE, WM_PAINT,
    WM_CLOSE, WM_QUIT, WM_ERASEBKGND, WM_SHOWWINDOW,
    WM_NCCREATE, WM_NCDESTROY, WM_KEYDOWN, WM_KEYUP, WM_CHAR,
    WM_COMMAND, WM_SYSCOMMAND, WM_TIMER, WM_HSCROLL, WM_VSCROLL,
    WM_MOUSEMOVE, WM_LBUTTONDOWN, WM_LBUTTONUP,
    WM_RBUTTONDOWN, WM_RBUTTONUP, WM_USER}

// MessageBox constants
public import windows_sys.{MB_OK, MB_OKCANCEL, MB_ABORTRETRYIGNORE,
    MB_YESNOCANCEL, MB_YESNO, MB_RETRYCANCEL,
    MB_ICONHAND, MB_ICONQUESTION, MB_ICONEXCLAMATION, MB_ICONASTERISK,
    MB_ICONERROR, MB_ICONWARNING, MB_ICONINFORMATION,
    IDOK, IDCANCEL, IDABORT, IDRETRY, IDIGNORE, IDYES, IDNO}

// ShowWindow / SetWindowPos constants
public import windows_sys.{SW_HIDE, SW_SHOWNORMAL, SW_SHOWMINIMIZED,
    SW_SHOWMAXIMIZED, SW_MAXIMIZE, SW_SHOWNOACTIVATE, SW_SHOW,
    SW_MINIMIZE, SW_SHOWMINNOACTIVE, SW_SHOWNA, SW_RESTORE, SW_SHOWDEFAULT,
    SWP_NOSIZE, SWP_NOMOVE, SWP_NOZORDER, SWP_SHOWWINDOW, CW_USEDEFAULT}

// Flags and file constants
public import windows_sys.{FILE_SHARE_MODE, FILE_ACCESS_FLAGS, FILE_CREATION_DISPOSITION,
    FILE_SHARE_NONE, FILE_SHARE_READ, FILE_SHARE_WRITE, FILE_SHARE_DELETE,
    GENERIC_READ, GENERIC_WRITE, GENERIC_EXECUTE, GENERIC_ALL,
    FILE_READ_DATA, FILE_WRITE_DATA, FILE_APPEND_DATA,
    FILE_READ_ATTRIBUTES, FILE_WRITE_ATTRIBUTES,
    CREATE_NEW, CREATE_ALWAYS, OPEN_EXISTING, OPEN_ALWAYS, TRUNCATE_EXISTING,
    FILE_ATTRIBUTE_READONLY, FILE_ATTRIBUTE_HIDDEN, FILE_ATTRIBUTE_SYSTEM,
    FILE_ATTRIBUTE_DIRECTORY, FILE_ATTRIBUTE_ARCHIVE, FILE_ATTRIBUTE_NORMAL,
    FILE_ATTRIBUTE_TEMPORARY,
    FILE_FLAG_WRITE_THROUGH, FILE_FLAG_OVERLAPPED, FILE_FLAG_NO_BUFFERING,
    FILE_FLAG_RANDOM_ACCESS, FILE_FLAG_SEQUENTIAL_SCAN, FILE_FLAG_DELETE_ON_CLOSE}

// Memory / wait / misc constants
public import windows_sys.{MEM_COMMIT, MEM_RESERVE, MEM_DECOMMIT, MEM_RELEASE,
    PAGE_NOACCESS, PAGE_READONLY, PAGE_READWRITE,
    PAGE_EXECUTE, PAGE_EXECUTE_READ, PAGE_EXECUTE_READWRITE,
    WAIT_OBJECT_0, WAIT_ABANDONED, WAIT_TIMEOUT, WAIT_FAILED, INFINITE,
    STD_INPUT_HANDLE, STD_OUTPUT_HANDLE, STD_ERROR_HANDLE,
    FILE_BEGIN, FILE_CURRENT, FILE_END}
