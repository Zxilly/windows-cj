        if (raw.isNull()) {
            throw windows_core.WindowsException(windows_core.E_POINTER)
        }
        ProcessDiagnosticInfo.fromAbiTake(raw)
    }

    public static func viewWinrtHandle(raw: CPointer<Unit>): ProcessDiagnosticInfo {
        ProcessDiagnosticInfo.viewOf(raw)
    }
}
