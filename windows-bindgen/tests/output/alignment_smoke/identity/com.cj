@When[feat_windows_win32_system_com == "on"]
@C
public struct ROT_FLAGS {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: ROT_FLAGS): Bool {
        return this.value == other.value
    }
    public operator func !=(other: ROT_FLAGS): Bool {
        return this.value != other.value
    }

    public func contains(other: ROT_FLAGS): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: ROT_FLAGS): ROT_FLAGS {
        return ROT_FLAGS(this.value | other.value)
    }
    public operator func &(other: ROT_FLAGS): ROT_FLAGS {
        return ROT_FLAGS(this.value & other.value)
    }
    public operator func !(): ROT_FLAGS {
        return ROT_FLAGS(!this.value)
    }
}

