@When[cfg.feat_windows_system]
public struct UserWatcherStatus {
    public let value: Int32

    public init() {
        this.value = 0
    }

    public init(value: Int32) {
        this.value = value
    }
    public static let Created = UserWatcherStatus(value: 0)
    public static let Started = UserWatcherStatus(value: 1)
    public static let EnumerationCompleted = UserWatcherStatus(value: 2)
    public static let Stopping = UserWatcherStatus(value: 3)
    public static let Stopped = UserWatcherStatus(value: 4)
    public static let Aborted = UserWatcherStatus(value: 5)

    public operator func ==(other: UserWatcherStatus): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UserWatcherStatus): Bool {
        return this.value != other.value
    }
}

