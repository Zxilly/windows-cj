        windows_interface.getActivationFactoryByName<IActivationFactory>(UserWatcher.runtimeName(), IActivationFactory.descriptor()).ok()
    }

    public static func isAgile(): Bool {
        true
    }

    public func asIInspectable(): IInspectable {
        IInspectable(asRaw())
    }

    public func asIUserWatcher(): IUserWatcher {
        IUserWatcher(asRaw())
    }

    public unsafe func Status(): UserWatcherStatus {
        return defaultInterface().Status()
    }

    public unsafe func Start(): Unit {
        defaultInterface().Start()
    }

    public unsafe func Stop(): Unit {
        defaultInterface().Stop()
    }

    public unsafe func Added(token: CPointer<Unit>): windows.foundation.EventRegistrationToken {
