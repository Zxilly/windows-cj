@C
public struct STGM {
    public var value: UInt32 = 0

    public init() {}

    public init(value: UInt32) {
        this.value = value
    }

    public operator func ==(other: STGM): Bool {
        return this.value == other.value
    }
    public operator func !=(other: STGM): Bool {
        return this.value != other.value
    }

    public func contains(other: STGM): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: STGM): STGM {
        return STGM(this.value | other.value)
    }
    public operator func &(other: STGM): STGM {
        return STGM(this.value & other.value)
    }
    public operator func !(): STGM {
        return STGM(!this.value)
    }
}

