        return defaultInterface().OpenReadAsync()
    }
}

@When[feat_windows_storage_streams == "on"]
@C
public struct UnicodeEncoding {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: UnicodeEncoding): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UnicodeEncoding): Bool {
        return this.value != other.value
    }
}

@When[feat_windows_storage_streams == "on"]
public let Utf8: UnicodeEncoding = UnicodeEncoding(0)

@When[feat_windows_storage_streams == "on"]
public let Utf16LE: UnicodeEncoding = UnicodeEncoding(1)

@When[feat_windows_storage_streams == "on"]
public let Utf16BE: UnicodeEncoding = UnicodeEncoding(2)
