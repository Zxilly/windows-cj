@When[feat_windows_storage_provider == "on"]
public let NoSyncRoot: StorageProviderUriSourceStatus = StorageProviderUriSourceStatus(1)

@When[feat_windows_storage_provider == "on"]
public let FileNotFound: StorageProviderUriSourceStatus = StorageProviderUriSourceStatus(2)

@When[feat_windows_storage_provider == "on"]
@C
public struct UIStatus {
    public var value: Int32 = 0

    public init() {}

    public init(value: Int32) {
        this.value = value
    }

    public operator func ==(other: UIStatus): Bool {
        return this.value == other.value
    }
    public operator func !=(other: UIStatus): Bool {
        return this.value != other.value
    }
}

@When[feat_windows_storage_provider == "on"]
public let Unavailable: UIStatus = UIStatus(0)

@When[feat_windows_storage_provider == "on"]
public let Hidden: UIStatus = UIStatus(1)

@When[feat_windows_storage_provider == "on"]
public let Visible: UIStatus = UIStatus(2)

@When[feat_windows_storage_provider == "on"]
public let Complete: UIStatus = UIStatus(3)

