@C
func TypedEventHandlerInvokeThunk(this_: CPointer<Unit>, arg0: CPointer<Unit>, arg1: CPointer<Unit>): Int32 {
    match (unsafe { asImplFromRaw<TypedEventHandlerInvoker>(this_) }) {
        case Some(invoker) =>
