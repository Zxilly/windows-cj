func buildIdleDispatchedHandlerBoxVtbl(): IdleDispatchedHandlerVtbl {
    var vtbl = IdleDispatchedHandlerVtbl()
    vtbl.base_ = buildIInspectableVtbl()
    vtbl.Invoke = IdleDispatchedHandlerInvokeThunk
