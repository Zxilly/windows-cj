@When[cfg.feat_windows_media_protection]
public struct RevocationAndRenewalReasons {
    public let value: UInt32

    public init() {
        this.value = 0
    }

    public init(value: UInt32) {
        this.value = value
    }
    public static let UserModeComponentLoad = RevocationAndRenewalReasons(value: 1)
    public static let KernelModeComponentLoad = RevocationAndRenewalReasons(value: 2)
    public static let AppComponent = RevocationAndRenewalReasons(value: 4)
    public static let GlobalRevocationListLoadFailed = RevocationAndRenewalReasons(value: 16)
    public static let InvalidGlobalRevocationListSignature = RevocationAndRenewalReasons(value: 32)
    public static let GlobalRevocationListAbsent = RevocationAndRenewalReasons(value: 4096)
    public static let ComponentRevoked = RevocationAndRenewalReasons(value: 8192)
    public static let InvalidComponentCertificateExtendedKeyUse = RevocationAndRenewalReasons(value: 16384)
    public static let ComponentCertificateRevoked = RevocationAndRenewalReasons(value: 32768)
    public static let InvalidComponentCertificateRoot = RevocationAndRenewalReasons(value: 65536)
    public static let ComponentHighSecurityCertificateRevoked = RevocationAndRenewalReasons(value: 131072)
    public static let ComponentLowSecurityCertificateRevoked = RevocationAndRenewalReasons(value: 262144)
    public static let BootDriverVerificationFailed = RevocationAndRenewalReasons(value: 1048576)
    public static let ComponentSignedWithTestCertificate = RevocationAndRenewalReasons(value: 16777216)
    public static let EncryptionFailure = RevocationAndRenewalReasons(value: 268435456)

    public operator func ==(other: RevocationAndRenewalReasons): Bool {
        return this.value == other.value
    }
    public operator func !=(other: RevocationAndRenewalReasons): Bool {
        return this.value != other.value
    }

    public func contains(other: RevocationAndRenewalReasons): Bool {
        return (this.value & other.value) == other.value
    }

    public operator func |(other: RevocationAndRenewalReasons): RevocationAndRenewalReasons {
        return RevocationAndRenewalReasons(value: this.value | other.value)
    }
    public operator func &(other: RevocationAndRenewalReasons): RevocationAndRenewalReasons {
        return RevocationAndRenewalReasons(value: this.value & other.value)
    }
    public operator func ~(): RevocationAndRenewalReasons {
        return RevocationAndRenewalReasons(value: ~this.value)
    }
}

