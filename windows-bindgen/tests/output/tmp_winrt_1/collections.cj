    public unsafe func GetAt(index: UInt32): T {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetAt(liveRaw, index)
    }

    public unsafe func Size(): UInt32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.Size(liveRaw)
    }

    public unsafe func IndexOf(value: T, index: CPointer<UInt32>): Bool {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.IndexOf(liveRaw, value, index)
    }

    public unsafe func GetMany(startIndex: UInt32, items: CPointer<T>): UInt32 {
        let v = vtbl()
        let liveRaw = asRaw()
        return v.GetMany(liveRaw, startIndex, items)
    }
}

@When[cfg.feat_windows_foundation_collections]
public type MapChangedEventHandler = CFunc<(CPointer<Unit>, CPointer<Unit>) -> Unit>

@When[cfg.feat_windows_foundation_collections]
public type VectorChangedEventHandler = CFunc<(CPointer<Unit>, IVectorChangedEventArgs) -> Unit>
