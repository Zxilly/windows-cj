package windows_bindgen

import std.collection.*
import std.sync.*

// Collect feature metadata from namespaces/modules and generate manifest files.

public class FeatureCollector {
    public let featureToDeps: HashMap<String, ArrayList<String>> = HashMap<String, ArrayList<String>>()
    public let featureToLinks: HashMap<String, ArrayList<String>> = HashMap<String, ArrayList<String>>()
    public let featureOrder: ArrayList<String> = ArrayList<String>()
    private let mutex_: Mutex = Mutex()

    public init() {}

    public func addNamespace(namespace: String): Unit {
        mutex_.lock()
        ensureFeature(this, namespaceToFeature(namespace))
        mutex_.unlock()
    }

    public func addBinding(namespace: String, moduleName: String): Unit {
        let namespaceFeature = namespaceToFeature(namespace)
        let moduleFeature = moduleToFeature(moduleName)

        mutex_.lock()
        ensureFeature(this, namespaceFeature)
        ensureFeature(this, moduleFeature)
        if (!featureToDeps.contains(namespaceFeature)) {
            featureToDeps[namespaceFeature] = ArrayList<String>()
        }
        if (!featureToLinks.contains(moduleFeature)) {
            featureToLinks[moduleFeature] = ArrayList<String>()
        }
        addUnique(featureToDeps[namespaceFeature], moduleFeature)
        addUnique(featureToLinks[moduleFeature], moduleLinkName(moduleName))
        mutex_.unlock()
    }

    // Generate features.toml content
    public func generateFeaturesToml(noComment: Bool): String {
        var sb = StringBuilder()
        if (!noComment) {
            sb.append("# Auto-generated by windows-bindgen\n")
            sb.append("# Feature definitions for conditional compilation\n\n")
        }

        let features = sortedFeatureKeys(this)
        for (feature in features) {
            sb.append("[features.${feature}]\n")
            sb.append("cfg = \"${feature}\"\n")
            let deps = sortedStringsForFeature(featureToDeps, feature)
            sb.append("deps = [${joinQuotedStrings(deps)}]\n\n")
        }

        return sb.toString()
    }

    // Generate link-options.toml content
    public func generateLinkOptionsToml(noComment: Bool): String {
        var sb = StringBuilder()
        if (!noComment) {
            sb.append("# Auto-generated by windows-bindgen\n")
            sb.append("# Link options per DLL module\n\n")
        }

        let features = sortedFeatureKeys(this)
        for (feature in features) {
            if (featureToLinks.contains(feature)) {
                sb.append("[features.${feature}]\n")
                let links = sortedStringsForFeature(featureToLinks, feature)
                var prefixedLinks = ArrayList<String>()
                for (link in links) {
                    prefixedLinks.add("-l${link}")
                }
                sb.append("link = [${joinQuotedStrings(prefixedLinks)}]\n\n")
            }
        }

        return sb.toString()
    }

    // Generate cfg.toml content with all discovered feature toggles enabled.
    public func generateCfgToml(noComment: Bool): String {
        var sb = StringBuilder()
        if (!noComment) {
            sb.append("# Auto-generated by windows-bindgen\n")
            sb.append("# Conditional compilation variables\n")
            sb.append("# Features enabled for the generated projection.\n\n")
        }

        let features = sortedFeatureKeys(this)
        for (feature in features) {
            sb.append("${feature} = \"on\"\n")
        }

        return sb.toString()
    }
}

func ensureFeature(collector: FeatureCollector, feature: String): Unit {
    if (!containsStr(collector.featureOrder, feature)) {
        collector.featureOrder.add(feature)
    }
}

func addUnique(list: ArrayList<String>, value: String): Unit {
    if (!containsStr(list, value)) {
        list.add(value)
    }
}

func sortedFeatureKeys(collector: FeatureCollector): ArrayList<String> {
    var result = ArrayList<String>()
    for (feature in collector.featureOrder) {
        result.add(feature)
    }
    sortTomlStrings(result)
    return result
}

func sortedStringsForFeature(map: HashMap<String, ArrayList<String>>, feature: String): ArrayList<String> {
    var result = ArrayList<String>()
    if (map.contains(feature)) {
        for (value in map[feature]) {
            result.add(value)
        }
    }
    sortTomlStrings(result)
    return result
}

func joinQuotedStrings(values: ArrayList<String>): String {
    var parts = ArrayList<String>()
    for (value in values) {
        parts.add("\"${value}\"")
    }
    return joinStringsLocal(parts, ", ")
}

func sortTomlStrings(values: ArrayList<String>): Unit {
    var i: Int64 = 1
    while (i < Int64(values.size)) {
        let key = values[i]
        var j = i - 1
        while (j >= 0 && values[j] > key) {
            values[j + 1] = values[j]
            j -= 1
        }
        values[j + 1] = key
        i += 1
    }
}

func joinStringsLocal(list: ArrayList<String>, sep: String): String {
    var sb = StringBuilder()
    var first = true
    for (s in list) {
        if (!first) {
            sb.append(sep)
        }
        sb.append(s)
        first = false
    }
    return sb.toString()
}

func moduleLinkName(moduleName: String): String {
    let baseName = stripDllExtension(moduleName)
    let arr = baseName.toArray()
    var result = Array<Byte>(
        arr.size,
        {
            i =>
                let ch = arr[i]
                if (ch >= b'A' && ch <= b'Z') {
                    ch - b'A' + b'a'
                } else {
                    ch
                }
        }
    )
    return String.fromUtf8(result)
}

func stripDllExtension(name: String): String {
    let arr = name.toArray()
    let len = Int64(arr.size)
    if (len > 4) {
        let suffix = String.fromUtf8(arr[len - 4..len])
        if (suffix == ".dll" || suffix == ".DLL") {
            return String.fromUtf8(arr[0..len - 4])
        }
    }
    return name
}

func containsStr(list: ArrayList<String>, s: String): Bool {
    for (item in list) {
        if (item == s) {
            return true
        }
    }
    return false
}
