package windows_bindgen

import std.collection.*
import std.sync.*

// Collect feature metadata from namespaces/modules and generate manifest files.

public class FeatureCollector {
    public let featureToDeps: HashMap<String, ArrayList<String>> = HashMap<String, ArrayList<String>>()
    public let featureToLinks: HashMap<String, ArrayList<String>> = HashMap<String, ArrayList<String>>()
    public let featureOrder: ArrayList<String> = ArrayList<String>()
    public let namespaces: ArrayList<String> = ArrayList<String>()
    private let mutex_: Mutex = Mutex()

    public init() {}

    public func addNamespace(namespace: String): Unit {
        mutex_.lock()
        registerNamespace(this, namespace)
        ensureFeature(this, namespaceToFeature(namespace))
        mutex_.unlock()
    }

    public func addNamespaceDependency(namespace: String, dependencyNamespace: String): Unit {
        mutex_.lock()
        registerNamespace(this, namespace)
        addNamespaceDependencyLocked(this, namespace, dependencyNamespace)
        mutex_.unlock()
    }

    public func addBinding(namespace: String, moduleName: String): Unit {
        let namespaceFeature = namespaceToFeature(namespace)
        let moduleFeature = moduleToFeature(moduleName)

        mutex_.lock()
        registerNamespace(this, namespace)
        ensureFeature(this, namespaceFeature)
        ensureFeature(this, moduleFeature)
        ensureDeps(this, namespaceFeature)
        if (!featureToLinks.contains(moduleFeature)) {
            featureToLinks[moduleFeature] = ArrayList<String>()
        }
        addUnique(featureToDeps[namespaceFeature], moduleFeature)
        addUnique(featureToLinks[moduleFeature], moduleLinkName(moduleName))
        mutex_.unlock()
    }

    // Generate features.toml content
    public func generateFeaturesToml(noComment: Bool): String {
        var sb = StringBuilder()
        if (!noComment) {
            sb.append("# Auto-generated by windows-bindgen\n")
            sb.append("# Feature definitions for conditional compilation\n\n")
        }

        let features = sortedFeatureKeys(this)
        for (feature in features) {
            sb.append("[features.${feature}]\n")
            sb.append("cfg = \"${feature}\"\n")
            let deps = sortedStringsForFeature(featureToDeps, feature)
            sb.append("deps = [${joinQuotedStrings(deps)}]\n\n")
        }

        return sb.toString()
    }

    // Generate link-options.toml content
    public func generateLinkOptionsToml(noComment: Bool): String {
        var sb = StringBuilder()
        if (!noComment) {
            sb.append("# Auto-generated by windows-bindgen\n")
            sb.append("# Link options per DLL module\n\n")
        }

        let features = sortedFeatureKeys(this)
        for (feature in features) {
            if (featureToLinks.contains(feature)) {
                sb.append("[features.${feature}]\n")
                let links = sortedStringsForFeature(featureToLinks, feature)
                var prefixedLinks = ArrayList<String>()
                for (link in links) {
                    prefixedLinks.add("-l${link}")
                }
                sb.append("link = [${joinQuotedStrings(prefixedLinks)}]\n\n")
            }
        }

        return sb.toString()
    }

    // Generate cfg_list.toml content with all discovered conditional compilation keys.
    public func generateCfgListToml(noComment: Bool, universe!: ArrayList<String> = ArrayList<String>()): String {
        var sb = StringBuilder()
        if (!noComment) {
            sb.append("# Auto-generated by windows-bindgen\n")
            sb.append("# Conditional compilation variables available to windows-cfggen.\n\n")
        }

        let features = cfgToggleKeys(this, universe)
        for (feature in features) {
            let value = if (containsStr(featureOrder, feature)) { "on" } else { "off" }
            sb.append("${feature} = \"${value}\"\n")
        }

        return sb.toString()
    }
}

func ensureFeature(collector: FeatureCollector, feature: String): Unit {
    if (!containsStr(collector.featureOrder, feature)) {
        collector.featureOrder.add(feature)
    }
}

func ensureDeps(collector: FeatureCollector, feature: String): Unit {
    if (!collector.featureToDeps.contains(feature)) {
        collector.featureToDeps[feature] = ArrayList<String>()
    }
}

func registerNamespace(collector: FeatureCollector, namespace: String): Unit {
    if (namespace.isEmpty() || containsStr(collector.namespaces, namespace)) {
        return
    }

    ensureNamespaceFeatureChain(collector, namespace)
    collector.namespaces.add(namespace)
}

func ensureNamespaceFeatureChain(collector: FeatureCollector, namespace: String): Unit {
    let chain = namespaceFeatureChain(namespace)
    var i: Int64 = 0
    while (i < Int64(chain.size)) {
        ensureFeature(collector, chain[i])
        if (i > 0) {
            ensureDeps(collector, chain[i])
            addUnique(collector.featureToDeps[chain[i]], chain[i - 1])
        }
        i += 1
    }
    ensureNamespaceRootDeps(collector)
}

func ensureNamespaceRootDeps(collector: FeatureCollector): Unit {
    if (containsStr(collector.featureOrder, "Windows_Win32") &&
        containsStr(collector.featureOrder, "Windows_Win32_Foundation")) {
        ensureDeps(collector, "Windows_Win32")
        addUnique(collector.featureToDeps["Windows_Win32"], "Windows_Win32_Foundation")
    }
    if (containsStr(collector.featureOrder, "Windows_Wdk") &&
        containsStr(collector.featureOrder, "Windows_Win32_Foundation")) {
        ensureDeps(collector, "Windows_Wdk")
        addUnique(collector.featureToDeps["Windows_Wdk"], "Windows_Win32_Foundation")
    }
    if (containsStr(collector.featureOrder, "Windows_Foundation")) {
        for (feature in collector.featureOrder) {
            if (isHighLevelRootFeature(feature)) {
                ensureDeps(collector, feature)
                addUnique(collector.featureToDeps[feature], "Windows_Foundation")
            }
        }
    }
}

func addNamespaceDependencyLocked(
    collector: FeatureCollector,
    namespace: String,
    dependencyNamespace: String
): Unit {
    if (namespace.isEmpty() || dependencyNamespace.isEmpty() || namespace == dependencyNamespace) {
        return
    }

    let namespaceFeature = namespaceToFeature(namespace)
    let dependencyFeature = namespaceToFeature(dependencyNamespace)
    if (namespaceFeature == dependencyFeature) {
        return
    }

    ensureNamespaceFeatureChain(collector, namespace)
    ensureNamespaceFeatureChain(collector, dependencyNamespace)
    ensureDeps(collector, namespaceFeature)
    addUnique(collector.featureToDeps[namespaceFeature], dependencyFeature)
}

func addUnique(list: ArrayList<String>, value: String): Unit {
    if (!containsStr(list, value)) {
        list.add(value)
    }
}

func sortedFeatureKeys(collector: FeatureCollector): ArrayList<String> {
    var result = ArrayList<String>()
    for (feature in collector.featureOrder) {
        result.add(feature)
    }
    sortTomlStrings(result)
    return result
}

func sortedStringsForFeature(map: HashMap<String, ArrayList<String>>, feature: String): ArrayList<String> {
    var result = ArrayList<String>()
    if (map.contains(feature)) {
        for (value in map[feature]) {
            result.add(value)
        }
    }
    sortTomlStrings(result)
    return result
}

func cfgToggleKeys(collector: FeatureCollector, universe: ArrayList<String>): ArrayList<String> {
    let result = ArrayList<String>()
    for (feature in universe) {
        if (!containsStr(result, feature)) {
            result.add(feature)
        }
    }
    for (feature in collector.featureOrder) {
        if (!containsStr(result, feature)) {
            result.add(feature)
        }
    }
    sortTomlStrings(result)
    return result
}

func joinQuotedStrings(values: ArrayList<String>): String {
    var parts = ArrayList<String>()
    for (value in values) {
        parts.add("\"${value}\"")
    }
    return joinStringsLocal(parts, ", ")
}

func sortTomlStrings(values: ArrayList<String>): Unit {
    var i: Int64 = 1
    while (i < Int64(values.size)) {
        let key = values[i]
        var j = i - 1
        while (j >= 0 && values[j] > key) {
            values[j + 1] = values[j]
            j -= 1
        }
        values[j + 1] = key
        i += 1
    }
}

func joinStringsLocal(list: ArrayList<String>, sep: String): String {
    var sb = StringBuilder()
    var first = true
    for (s in list) {
        if (!first) {
            sb.append(sep)
        }
        sb.append(s)
        first = false
    }
    return sb.toString()
}

func moduleLinkName(moduleName: String): String {
    let baseName = stripDllExtension(moduleName)
    let arr = baseName.toArray()
    var result = Array<Byte>(
        arr.size,
        {
            i =>
                let ch = arr[i]
                if (ch >= b'A' && ch <= b'Z') {
                    ch - b'A' + b'a'
                } else {
                    ch
                }
        }
    )
    return String.fromUtf8(result)
}

func stripDllExtension(name: String): String {
    let arr = name.toArray()
    let len = Int64(arr.size)
    if (len > 4) {
        let suffix = String.fromUtf8(arr[len - 4..len])
        if (suffix == ".dll" || suffix == ".DLL") {
            return String.fromUtf8(arr[0..len - 4])
        }
    }
    return name
}

func containsStr(list: ArrayList<String>, s: String): Bool {
    for (item in list) {
        if (item == s) {
            return true
        }
    }
    return false
}

func isHighLevelRootFeature(feature: String): Bool {
    if (!feature.startsWith("Windows_")) {
        return false
    }
    if (feature == "Windows_Foundation" || feature == "Windows_Win32" || feature == "Windows_Wdk") {
        return false
    }

    let bytes = feature.toArray()
    var underscoreCount: Int64 = 0
    for (ch in bytes) {
        if (ch == b'_') {
            underscoreCount += 1
        }
    }
    return underscoreCount == 1
}

func namespaceFeatureChain(namespace: String): ArrayList<String> {
    let parts = splitString(namespace, b'.')
    let chain = ArrayList<String>()
    if (parts.size == 0) {
        return chain
    }

    var startIndex: Int64 = 0
    if (parts[0] == "Windows" && parts.size > 1) {
        startIndex = 1
    }

    var i = startIndex
    while (i < Int64(parts.size)) {
        let currentParts = ArrayList<String>()
        var j: Int64 = 0
        while (j <= i) {
            currentParts.add(parts[j])
            j += 1
        }
        chain.add(namespaceToFeature(joinStringsLocal(currentParts, ".")))
        i += 1
    }
    return chain
}
