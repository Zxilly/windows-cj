package windows_bindgen

import std.collection.*
import windows_metadata.*

public class LibraryCollector {
    private let linkPackage_: String
    private let libraries_: HashMap<String, ArrayList<String>>

    public init(linkPackage: String) {
        this.linkPackage_ = if (linkPackage.isEmpty()) { "windows_core" } else { linkPackage }
        this.libraries_ = HashMap<String, ArrayList<String>>()
    }

    public func collect(index: TypeIndex, typeMap: TypeMap): Unit {
        for (namespace in typeMap.namespaces()) {
            for (entry in typeMap.typesInNamespace(namespace)) {
                let (mStart, mEnd) = index.typeDefMethods(entry.fileIdx, entry.row)
                var methodRow = mStart
                while (methodRow < mEnd) {
                    match (index.methodDefImplMap(entry.fileIdx, methodRow)) {
                        case Some((_, importName, moduleName)) =>
                            let library = stripDllExtension(moduleName)
                            if (!libraries_.contains(library)) {
                                libraries_[library] = ArrayList<String>()
                            }
                            addUnique(libraries_[library], importName)
                        case None => ()
                    }
                    methodRow += 1
                }
            }
        }
    }

    public func generateSource(noComment: Bool): String {
        let builder = StringBuilder()
        if (!noComment) {
            builder.append("// Auto-generated by windows-bindgen. Do not edit.\n")
        }
        builder.append("package windows_bindgen_artifacts\n\n")
        builder.append("public let defaultLinkPackage: String = \"${linkPackage_}\"\n")

        let libraryNames = ArrayList<String>()
        for ((name, _) in libraries_) {
            libraryNames.add(name)
        }
        sortStrings(libraryNames)

        builder.append("public let libraries: Array<String> = [")
        var i: Int64 = 0
        while (i < Int64(libraryNames.size)) {
            if (i > 0) {
                builder.append(", ")
            }
            builder.append("\"${libraryNames[i]}\"")
            i += 1
        }
        builder.append("]\n")

        let encodedFunctions = ArrayList<String>()
        for (library in libraryNames) {
            let functions = libraries_[library]
            sortStrings(functions)
            for (functionName in functions) {
                encodedFunctions.add("${library}:${functionName}")
            }
        }
        builder.append("public let libraryFunctions: Array<String> = [")
        var fi: Int64 = 0
        while (fi < Int64(encodedFunctions.size)) {
            if (fi > 0) {
                builder.append(", ")
            }
            builder.append("\"${encodedFunctions[fi]}\"")
            fi += 1
        }
        builder.append("]\n")
        return builder.toString()
    }
}
